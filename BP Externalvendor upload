FORM BDC_DYNPRO USING PROGRAM DYNPRO.
  CLEAR BDCDATA.
  BDCDATA-PROGRAM  = PROGRAM.
  BDCDATA-DYNPRO   = DYNPRO.
  BDCDATA-DYNBEGIN = 'X'.
  APPEND BDCDATA.
ENDFORM.

*----------------------------------------------------------------------*
*        Insert field                                                  *
*----------------------------------------------------------------------*
FORM BDC_FIELD USING FNAM FVAL.
  IF FVAL <> SPACE."NODATA.
    CLEAR BDCDATA.
    BDCDATA-FNAM = FNAM.
    BDCDATA-FVAL = FVAL.
    APPEND BDCDATA.
  ENDIF.
ENDFORM.
FORM F_BUILD_FCAT USING P_FNAME TYPE DD03P-FIELDNAME P_OUTPUTLEN TYPE  DD03P-OUTPUTLEN  P_SELTEXT TYPE DD03P-SCRTEXT_L CHANGING P_IT_FCAT TYPE SLIS_T_FIELDCAT_ALV.
  CLEAR W_FCAT.
  W_FCAT-FIELDNAME = P_FNAME.
  W_FCAT-SELTEXT_L = P_SELTEXT.
  W_FCAT-OUTPUTLEN = P_OUTPUTLEN.
  APPEND W_FCAT TO P_IT_FCAT.
ENDFORM.
