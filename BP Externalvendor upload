    PERFORM BDC_FIELD       USING 'ADDR1_DATA-COUNTRY'
                                  gs_file-COUNTRY."'IN'.
    PERFORM BDC_FIELD       USING 'ADDR1_DATA-REGION'
                                  gs_file-REGION."'03'.
    PERFORM BDC_FIELD       USING 'ADDR1_DATA-LANGU'
