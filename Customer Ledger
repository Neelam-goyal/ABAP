REPORT zfi_rep_cust_ledger.

include zfi_rep_cust_ledger_top.
include zfi_rep_cust_ledger_get.
include zfi_rep_cust_ledger_disp.

start-of-selection.
  perform get_data.
  perform final_data.

END-OF-SELECTION.
  if S_SCR eq 'X'.
     g_repid = sy-repid.
     perform f_list.
  elseif S_PRN eq 'X'.
     select single concat( name1 , name2 ) FROM kna1  where kunnr eq @skunnr-low INTO  @gv_custname.
     concatenate 'account : ' gv_custname into gv_custname separated by space.
     CALL FUNCTION 'SSF_FUNCTION_MODULE_NAME'
      exporting
        formname = c_formname
      importing
        fm_name  = fm_name.

     IF SY-SUBRC <> 0.
       WRITE 'Function module not found.'.
     ENDIF.

     call function fm_name
      exporting
        pfdate   = sdate-low
        ptdate   = sdate-high
        pkunnr   = skunnr-low
        pbukrs   = gv_compname
      tables
        it_final = it_fin.

  endif.


