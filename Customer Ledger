*&---------------------------------------------------------------------*
*&  Include           ZFI_REP_CUSTOMER_LEDGER_GET
*&---------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*&      Form  GET_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM GET_DATA.
  IF P_AMTLC EQ 'X'.
     LV_CURR = 'X'.
  ELSEIF P_AMTFC EQ 'X'.
    LV_CURR = 'Y'.
  ENDIF.
  CALL FUNCTION 'Z_FI_CUST_BAL'
    EXPORTING
      SBUKRS  = SBUKRS
      FROMDT  = SDATE-LOW
      TODT    = SDATE-HIGH
      LV_CURR = LV_CURR
      VENDOR = LV_V
    IMPORTING
      RETURN  = RETURN
    TABLES
      SKUNNR  = SKUNNR
      SPRCTR  = SPRCTR
      OPENBAL = OPENBAL
      TACDOCA = TACDOCA.

  SELECT RCLNT RLDNR RBUKRS GJAHR BELNR DOCLN RYEAR RTCUR RACCT RCNTR PRCTR HSL DRCRK BUDAT BLDAT BLART ZUONR BSCHL SGTXT KUNNR KUNNR
         KOART UMSKZ AUGDT AUGBL WERKS WSL KTOSL FROM ACDOCA INTO TABLE TACDOCA2 FOR ALL ENTRIES IN TACDOCA WHERE RLDNR = '0L'
         AND RBUKRS = SBUKRS
         AND BELNR  = TACDOCA-BELNR
*         AND BLART NE 'SU'
         AND BUDAT  IN SDATE
         AND AWREF_REV EQ ''.

  IF SY-SUBRC IS INITIAL.
     REFRESH LT_ACDOCA_TDS .
     LT_ACDOCA_TDS = TACDOCA2[].
     DELETE TACDOCA2 WHERE KOART <> 'D'.
     DELETE LT_ACDOCA_TDS  WHERE KTOSL <> 'WIT'.
     SORT LT_ACDOCA_TDS BY RBUKRS BELNR GJAHR PRCTR.
     SELECT * FROM T003T INTO TABLE LT_T003T FOR ALL ENTRIES IN TACDOCA2 WHERE SPRAS EQ SY-LANGU AND BLART EQ TACDOCA2-BLART.
  ENDIF.

  SELECT KUNNR NAME1 FROM KNA1 INTO TABLE TKNA1 WHERE KUNNR IN SKUNNR.
  SELECT KOSTL LTEXT FROM CSKT INTO TABLE LT_CSKT FOR ALL ENTRIES IN TACDOCA WHERE SPRAS = 'E' AND KOKRS = 'CDBG' AND KOSTL = TACDOCA-RCNTR.
  IF TACDOCA IS NOT INITIAL.
    SELECT BUKRS
           BELNR
           GJAHR
           BLDAT
           BUDAT
           CPUDT
           XBLNR
           BKTXT FROM BKPF INTO TABLE TBKPF
           FOR ALL ENTRIES IN TACDOCA
           WHERE BUKRS = SBUKRS
           AND   BELNR = TACDOCA-BELNR
           AND   GJAHR = TACDOCA-GJAHR.

    IF TACDOCA2 IS NOT INITIAL.
    ENDIF.

    SELECT * FROM SKAT INTO TABLE TSKAT       FOR ALL ENTRIES IN TACDOCA  WHERE SAKNR = TACDOCA-RACCT.
    SELECT * FROM SKAT APPENDING TABLE TSKAT  FOR ALL ENTRIES IN TACDOCA2 WHERE SAKNR = TACDOCA2-RACCT.
    SELECT * FROM CEPCT INTO TABLE TCEPCT     FOR ALL ENTRIES IN TACDOCA  WHERE PRCTR = TACDOCA-PRCTR.

  ENDIF.

  IF TACDOCA IS NOT INITIAL.
     SELECT * FROM T074T INTO TABLE TT074T FOR ALL ENTRIES IN TACDOCA WHERE SPRAS = 'E' AND KOART = TACDOCA-KOART AND SHBKZ = TACDOCA-UMSKZ.
  ENDIF.

  IF TACDOCA2 IS NOT INITIAL.
     SELECT * FROM T074T APPENDING TABLE TT074T FOR ALL ENTRIES IN TACDOCA2 WHERE SPRAS = 'E' AND   KOART = TACDOCA2-KOART AND   SHBKZ = TACDOCA2-UMSKZ.
     SELECT KOSTL LTEXT FROM CSKT INTO TABLE LT_CSKT2 FOR ALL ENTRIES IN TACDOCA2 WHERE SPRAS = 'E' AND KOKRS = 'CDBG' AND KOSTL = TACDOCA2-RCNTR.
  ENDIF.

  select single werks into gv_plant from bseg where bukrs eq sbukrs and werks <> ''.
  select single name1, name2 from t001w into @data(wa_comp_name) where werks eq @gv_plant.
  concatenate wa_comp_name-name1 wa_comp_name-name2 into gv_compname separated by space.
  translate gv_compname to upper case.

ENDFORM.


*&---------------------------------------------------------------------*
*&      Form  FINAL_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM FINAL_DATA .
*  SORT TACDOCA BY KUNNR PRCTR+0(4) BUDAT BELNR ."DESCENDING.
  data : wa_vbrk type vbrk.
  data : t_tmp type table of zacdoca,
         p_tmp type table of zacdoca,
         w_tmp type zacdoca.

  SORT TACDOCA BY KUNNR BUDAT BELNR.

  DATA : LV_TMP TYPE I.

  t_tmp[] = tacdoca[].
  p_tmp[] = tacdoca[].

  DELETE ADJACENT DUPLICATES FROM T_TMP COMPARING KUNNR BUDAT BELNR.

  FIELD-SYMBOLS <LFS_OPENBAL> TYPE ZKUNNRBAL.
  REFRESH      LT_OPENBAL[].
  LT_OPENBAL[] = OPENBAL[].

  sort openbal by kunnr.

"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
  if R_CLEAR eq ''.    """ ADDED VISHAL
     delete tacdoca where blart = 'AB' .
  endif.

  LOOP AT T_TMP INTO W_TMP WHERE BLART EQ 'DZ'.
       LV_TMP = 1.
       LOOP AT TACDOCA INTO WACDOCA WHERE BELNR EQ W_TMP-BELNR AND GJAHR EQ W_TMP-GJAHR.
            WACDOCA-SRNO = LV_TMP.
            LV_TMP = LV_TMP + 1.
            MODIFY TACDOCA FROM WACDOCA.
       ENDLOOP.
  ENDLOOP.

  delete tacdoca where SRNO gt 1 and blart eq 'DZ'.

  LOOP AT TACDOCA INTO WACDOCA WHERE BLART EQ 'DZ'.
       WACDOCA-HSL = 0.
       LOOP AT P_TMP INTO W_TMP WHERE BELNR EQ WACDOCA-BELNR AND GJAHR EQ WACDOCA-GJAHR.
            WACDOCA-HSL = WACDOCA-HSL + W_TMP-HSL.
       ENDLOOP.
       IF WACDOCA-HSL GT 0.
          WACDOCA-DRCRK = 'S'.
       ELSE.
          WACDOCA-DRCRK = 'H'.
       ENDIF.
       MODIFY TACDOCA FROM WACDOCA.
  ENDLOOP.

  LOOP AT TACDOCA INTO WACDOCA WHERE BUDAT IN SDATE AND KOART = 'D'.
    IF CUSTOMER <> WACDOCA-KUNNR.
      CLEAR : CLOSEBAL.
      READ TABLE OPENBAL ASSIGNING <LFS_OPENBAL> WITH KEY KUNNR = WACDOCA-KUNNR.
      IF SY-SUBRC = 0.
         WOPENBAL = <LFS_OPENBAL>.
         WFINAL-OPENBAL = WOPENBAL-HSL.
      ENDIF.
    ENDIF.

    WFINAL-RBUKRS = WACDOCA-RBUKRS.
    WFINAL-GJAHR  = WACDOCA-GJAHR.
    WFINAL-BELNR  = WACDOCA-BELNR.
    WFINAL-WERKS  = WACDOCA-PRCTR+0(4).
    IF WACDOCA-DRCRK EQ 'H'.
       WFINAL-SHKZG  = 'CR'.
    ELSEIF WACDOCA-DRCRK EQ 'S'.
       WFINAL-SHKZG  = 'DR'.
    ENDIF.
    BELNR         = WACDOCA-BELNR.
    READ TABLE TBKPF INTO WBKPF WITH KEY BELNR = WACDOCA-BELNR BUDAT = WACDOCA-BUDAT.
    IF SY-SUBRC = 0.
       WFINAL-XBLNR  = WBKPF-XBLNR.
       WFINAL-BKTXT  = WBKPF-BKTXT.
       WFINAL-AUGDT  = WBKPF-CPUDT.
    ENDIF.
    READ TABLE TKNA1 INTO WKNA1 WITH KEY KUNNR = WACDOCA-KUNNR.
    IF SY-SUBRC = 0.
       WFINAL-NAME1 = WKNA1-NAME1.
    ENDIF.
    WFINAL-RYEAR  = WACDOCA-RYEAR.
    WFINAL-RTCUR  = WACDOCA-RTCUR.
    WFINAL-RACCT  = WACDOCA-RACCT.
    READ TABLE TSKAT INTO WSKAT WITH KEY SAKNR = WACDOCA-RACCT.
    IF SY-SUBRC = 0.
       WFINAL-TXT50 = WSKAT-TXT50.
    ENDIF.
    WFINAL-RCNTR  = WACDOCA-RCNTR.
    WFINAL-PRCTR  = WACDOCA-PRCTR.
    PRCTR         = WACDOCA-PRCTR.
    CUSTOMER      = WACDOCA-KUNNR.
    IF LV_CURR EQ 'Y'.
       WACDOCA-HSL =  WACDOCA-WSL.
    ENDIF.

    WFINAL-HSLDEB  = WACDOCA-HSL .
    READ TABLE TT074T INTO WT074T WITH KEY KOART = WACDOCA-KOART SHBKZ = WACDOCA-UMSKZ.
    IF SY-SUBRC = 0.
       WFINAL-LTEXT1 = WT074T-LTEXT.
    ENDIF.
    WFINAL-BUDAT  = WACDOCA-BUDAT.
    WFINAL-BLDAT  = WACDOCA-BLDAT.
    WFINAL-BLART  = WACDOCA-BLART.

    CLEAR LW_T003T.
    READ TABLE LT_T003T INTO LW_T003T WITH KEY BLART = WACDOCA-BLART.
    IF SY-SUBRC IS INITIAL.
       WFINAL-BLART_DES  = LW_T003T-LTEXT.
    ENDIF.

    WFINAL-ZUONR  = WACDOCA-ZUONR.
    WFINAL-BSCHL  = WACDOCA-BSCHL.
    WFINAL-SGTXT  = WACDOCA-SGTXT.
    IF WACDOCA-KOART = 'D'.
       WFINAL-KUNNR  = WACDOCA-KUNNR.
    ENDIF.

    WFINAL-KOART  = WACDOCA-KOART.
    IF WACDOCA-KOART = 'D'.
       WFINAL-KUNNR  = WACDOCA-KUNNR.
    ENDIF.
    WFINAL-UMSKZ  = WACDOCA-UMSKZ.
    WFINAL-AUGBL  = WACDOCA-AUGBL.
    CLOSEBAL      = CLOSEBAL + WFINAL-OPENBAL + WACDOCA-HSL.
    WFINAL-CLOSEBAL = CLOSEBAL.

    <LFS_OPENBAL>-HSL = CLOSEBAL.

    IF WACDOCA-DRCRK = 'H'.
       WFINAL-HSLDEB  = WACDOCA-HSL .
    ENDIF.
    READ TABLE LT_CSKT INTO DATA(WA_CSKT) WITH KEY KOSTL = WFINAL-RCNTR.
    IF SY-SUBRC EQ 0.
       WFINAL-LTEXT = WA_CSKT-LTEXT.
       CLEAR : WA_CSKT.
    ENDIF.
    CLEAR LW_ACDOCA_TDS.
    READ TABLE LT_ACDOCA_TDS INTO LW_ACDOCA_TDS WITH KEY RBUKRS = WACDOCA-RBUKRS BELNR = WACDOCA-BELNR GJAHR = WACDOCA-GJAHR.

    IF SY-SUBRC IS INITIAL.
      IF LV_CURR EQ 'Y'.
        WFINAL-TDS =  LW_ACDOCA_TDS-WSL.
      ELSE.
        WFINAL-TDS =  LW_ACDOCA_TDS-HSL.
      ENDIF.
    ENDIF.
    APPEND WFINAL TO TFINAL.
    CLEAR : WFINAL,WKNA1,WSKAT,WT074T.

    LOOP AT TACDOCA2 INTO WACDOCA2 WHERE BELNR = BELNR
                                   AND DOCLN <> WACDOCA-DOCLN
                                   AND BUDAT IN SDATE
                                   AND KOART <> 'D'.
      WFINAL-RBUKRS = WACDOCA2-RBUKRS.
      WFINAL-GJAHR  = WACDOCA2-GJAHR.
      WFINAL-BELNR  = WACDOCA2-BELNR.
      WFINAL-XBLNR  = WBKPF-XBLNR.
      WFINAL-BKTXT  = WBKPF-BKTXT.
      WFINAL-AUGDT  = WBKPF-CPUDT.
      WFINAL-RYEAR  = WACDOCA2-RYEAR.
      WFINAL-RTCUR  = WACDOCA2-RTCUR.
      CLEAR LW_ACDOCA_TDS.
      READ TABLE LT_ACDOCA_TDS INTO LW_ACDOCA_TDS WITH KEY RBUKRS = WACDOCA2-RBUKRS BELNR = WACDOCA2-BELNR GJAHR = WACDOCA2-GJAHR.
      IF SY-SUBRC IS INITIAL.
         IF LV_CURR EQ 'Y'.
            WFINAL-TDS =  LW_ACDOCA_TDS-WSL.
         ELSE.
            WFINAL-TDS =  LW_ACDOCA_TDS-HSL.
         ENDIF.
      ENDIF.

      IF WACDOCA2-DRCRK EQ 'H'.
        WFINAL-SHKZG  = 'CR' ."wacdoca-drcrk.
      ELSEIF WACDOCA2-DRCRK EQ 'S'.
        WFINAL-SHKZG  = 'DR'.
      ENDIF.

      READ TABLE TT074T INTO WT074T WITH KEY KOART = WACDOCA2-KOART SHBKZ = WACDOCA2-UMSKZ.
      IF SY-SUBRC = 0.
        WFINAL-LTEXT1 = WT074T-LTEXT.
      ENDIF.
      READ TABLE TSKAT INTO WSKAT WITH KEY SAKNR = WACDOCA2-RACCT.
      IF SY-SUBRC = 0.
        WFINAL-TXT50 = WSKAT-TXT50.
      ENDIF.
      WFINAL-RACCT  = WACDOCA2-RACCT.
      WFINAL-RCNTR  = WACDOCA2-RCNTR.
      WFINAL-PRCTR  = WACDOCA2-PRCTR.

      IF LV_CURR EQ 'Y'.
         WACDOCA2-HSL =  WACDOCA2-WSL.
      ENDIF.

      IF WACDOCA2-DRCRK = 'S'.
         WFINAL-HSLDEB    = WACDOCA2-HSL .
      ELSEIF WACDOCA2-DRCRK = 'H'.
         WFINAL-HSLDEB     = WACDOCA2-HSL .
      ENDIF.
      READ TABLE TKNA1 INTO WKNA1 WITH KEY KUNNR = WACDOCA2-KUNNR.
      IF SY-SUBRC = 0.
         WFINAL-NAME1 = WKNA1-NAME1.
      ENDIF.
      WFINAL-BUDAT  = WACDOCA2-BUDAT.
      WFINAL-BLDAT  = WACDOCA2-BLDAT.
      WFINAL-BLART  = WACDOCA2-BLART.

      CLEAR LW_T003T.
      READ TABLE LT_T003T INTO LW_T003T WITH KEY BLART = WACDOCA2-BLART.
      IF SY-SUBRC IS INITIAL.
         WFINAL-BLART_DES  = LW_T003T-LTEXT.
      ENDIF.
      WFINAL-ZUONR  = WACDOCA2-ZUONR.
      WFINAL-BSCHL  = WACDOCA2-BSCHL.
      WFINAL-SGTXT  = WACDOCA2-SGTXT.
      WFINAL-KUNNR  = WACDOCA2-KUNNR.
      WFINAL-KOART  = WACDOCA2-KOART.
      IF WACDOCA2-KOART = 'D'.
         WFINAL-KUNNR  = WACDOCA2-KUNNR.
      ENDIF.
      WFINAL-UMSKZ  = WACDOCA2-UMSKZ.
      WFINAL-AUGBL  = WACDOCA2-AUGBL.
      READ TABLE LT_CSKT2 INTO DATA(WA_CSKT2) WITH KEY KOSTL = WFINAL-RCNTR.
      IF SY-SUBRC EQ 0.
         WFINAL-LTEXT = WA_CSKT2-LTEXT.
         CLEAR : WA_CSKT2.
      ENDIF.
      APPEND WFINAL TO TFINAL.
      DELETE TACDOCA2.
      CLEAR : WACDOCA2,WFINAL,WKNA1,WSKAT.
    ENDLOOP.
    CLEAR : WFINAL,WACDOCA,WACDOCA2,BELNR.
  ENDLOOP.
*
  CLEAR : CLOSEBAL.

  READ TABLE OPENBAL ASSIGNING <LFS_OPENBAL> WITH KEY KUNNR = SKUNNR-LOW.
  IF SY-SUBRC = 0.
     WOPENBAL = <LFS_OPENBAL>.
     wa_fin-color   = 'C51'.
     wa_fin-budat   = sdate-low.
     wa_fin-sgtxt   = 'Opening Balance'.
     wa_fin-clblamt = abs( WOPENBAL-HSL - WOPENBAL-CSL ).
*     if wfinal-closebal gt 0.
   READ TABLE LT_OPENBAL into data(wa) WITH KEY KUNNR = SKUNNR-LOW.
     if wa-HSL gt 0.
        wa_fin-drcrt = 'Dr'.
     else.
        wa_fin-drcrt = 'Cr'.
     endif.
     append wa_fin to it_fin.
     clear wa_fin.
  ENDIF.

  loop at tfinal into wfinal.
      wa_fin-bukrs   = wfinal-rbukrs.
      wa_fin-belnr   = wfinal-belnr.
      wa_fin-gjahr   = wfinal-gjahr.
      wa_fin-blart   = wfinal-blart.
      wa_fin-budat   = wfinal-budat.

      wa_fin-bldat   = wfinal-bldat.
      wa_fin-xblnr   = wfinal-xblnr.
      wa_fin-prctr   = wfinal-prctr.
      wa_fin-sgtxt   = wfinal-sgtxt.

      if wa_fin-sgtxt eq '' and wa_fin-blart eq 'RV'.
         select single * into wa_vbrk from vbrk where bukrs eq wfinal-rbukrs and belnr eq wfinal-belnr and gjahr eq wfinal-gjahr.
         if wa_vbrk-fkart eq 'ZANF' or wa_vbrk-fkart eq 'ZAST' or wa_vbrk-fkart eq 'ZCJW' or wa_vbrk-fkart eq 'ZOTG' or
            wa_vbrk-fkart eq 'ZCLQ' or wa_vbrk-fkart eq 'ZETH' or wa_vbrk-fkart eq 'ZIMF' or wa_vbrk-fkart eq 'ZOTH' or
            wa_vbrk-fkart eq 'ZSCR' or wa_vbrk-fkart eq 'ZSPE' or wa_vbrk-fkart eq 'ZSPG'.
            CONCATENATE 'Sales Against Invoice No. ' wa_fin-xblnr into wa_fin-sgtxt SEPARATED BY space.
         elseif wa_vbrk-fkart eq 'ZREN' or wa_vbrk-fkart eq 'ZREE' or wa_vbrk-fkart eq 'ZCME' or wa_vbrk-fkart eq 'ZCMR'.
            CONCATENATE 'Sales Credit Note Agst Invoice No.' wa_fin-xblnr into wa_fin-sgtxt SEPARATED BY space.
         elseif wa_vbrk-fkart eq 'ZDME' or wa_vbrk-fkart eq 'ZDMG' .
            CONCATENATE 'Sales Debit Note No. ' wa_fin-xblnr into wa_fin-sgtxt SEPARATED BY space.
         endif.
         wa_fin-xblnr = wa_vbrk-vbeln.
      endif.

      if wfinal-hsldeb gt 0.
         wa_fin-dramt   = abs( wfinal-hsldeb ).
      elseif wfinal-hsldeb lt 0.
         wa_fin-cramt   = abs( wfinal-hsldeb ).
      endif.
      wa_fin-clblamt = abs( wfinal-closebal ).
      wa_fin-tdsam   = abs( wfinal-tds ).
      lv_totdbamt    = lv_totdbamt + wa_fin-dramt.
      lv_totcramt    = lv_totcramt + wa_fin-cramt.
      if wfinal-closebal gt 0.
         wa_fin-drcrt = 'Dr'.
      else.
         wa_fin-drcrt = 'Cr'.
      endif.
      append wa_fin to it_fin.
      clear wa_fin.
  endloop.
ENDFORM.

