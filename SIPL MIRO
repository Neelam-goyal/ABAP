    """"***Duplicate invoice validation: Start
IF headerdata-reversedocument is INITIAL.

    select * from I_OperationalAcctgDocCube with PRIVILEGED ACCESS
                where Supplier   = @headerdata-INVOICINGPARTY and
                      IsReversal = '' and
                      IsReversed = '' and
                      financialaccounttype = 'K' and
                      documentreferenceid =  @headerdata-supplierinvoiceidbyinvcgparty and
                      (  accountingdocumenttype = 'RE' or accountingdocumenttype = 'KR' )
                      into table @data(it_bkpf).

      loop at  it_bkpf into data(wa_bkpf).
            lv_mm = wa_bkpf-DocumentDate+4(2).
            lv_yy = wa_bkpf-DocumentDate(4).
            if lv_mm ge '01' and lv_mm lt '04'.
                lv_yy = lv_yy - 1.
            endif.
            wa_bkpf-invoicereferencefiscalyear = lv_yy.
            modify it_bkpf from wa_bkpf transporting invoicereferencefiscalyear.
     endloop.

     lv_mm = headerdata-documentdate+4(2).
     lv_yy = headerdata-documentdate(4).
     if lv_mm ge '01' and lv_mm lt '04'.
        lv_yy = lv_yy - 1.
     endif.

     loop at it_bkpf into data(wa_bkpf1).
        if wa_bkpf-invoicereferencefiscalyear = lv_yy.
           APPEND VALUE #( messagetype = if_ex_mrm_check_invoice_cloud=>c_messagetype_error
                messageid = 'MRM_BADI_CLOUD'
                messagenumber = '001'
                messagevariable1 = 'Z: Duplicate Vendor Invoice Found'  ) TO messages.
           RETURN.
        endif.
     endloop.

endif.

    """"***Duplicate invoice validation: End
ENDIF.
