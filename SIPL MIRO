   if wa_item_new-taxcode ne 'V0'. "Add By Vishal Tyagi on 19092025
     IF wa_item_new-taxcode = 'A1' OR   "add By Vishal Tyagi on 25092925
          wa_item_new-taxcode = 'A2' OR
          wa_item_new-taxcode = 'A3' OR
          wa_item_new-taxcode = 'A4' OR
         wa_item_new-taxcode = 'A5' OR
          wa_item_new-taxcode = 'A6' OR
          wa_item_new-taxcode = 'A7' OR
          wa_item_new-taxcode = 'A8'.

        IF ls_lfa1-taxnumber3+0(2) = ls_plant-in_gstidentificationnumber+0(2).

          IF wa_item_new-taxcode = 'A1' OR
             wa_item_new-taxcode = 'A2' OR
             wa_item_new-taxcode = 'A3' OR
             wa_item_new-taxcode = 'A4'.

          ELSE.

            APPEND VALUE #( messagetype = if_ex_mrm_check_invoice_cloud=>c_messagetype_error
                          messageid = 'MRM_BADI_CLOUD'
                          messagenumber = '001'
                          messagevariable1 = 'Z: Invalid Tax code'  ) TO messages.
            EXIT.

          ENDIF.

        ELSE.

          IF wa_item_new-taxcode = 'A5' OR
             wa_item_new-taxcode = 'A6' OR
             wa_item_new-taxcode = 'A7' OR
             wa_item_new-taxcode = 'A8'.

          ELSE.

            APPEND VALUE #( messagetype = if_ex_mrm_check_invoice_cloud=>c_messagetype_error
                          messageid = 'MRM_BADI_CLOUD'
                          messagenumber = '001'
                          messagevariable1 = 'Z: Invalid Tax code'  ) TO messages.
            EXIT.

          ENDIF.

        ENDIF.

        CLEAR: wa_item_new.
      ENDIF.
    ENDIF.
    ENDLOOP.



