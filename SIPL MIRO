                      messagevariable1 = 'Z: Plant Business Place Mis-match'  ) TO messages.
        RETURN.
      ENDIF.

      SELECT SINGLE matldoclatestpostgdate FROM i_materialledgercube_lit
      WHERE purchasingdocument = @wa_item-purchaseorder


      AND   fiscalyear = @wa_item-referencedocumentfiscalyear
      AND  companycode = @headerdata-companycode
      AND ledger = '0L'
      INTO @DATA(lv_mirodate)
      PRIVILEGED ACCESS.
