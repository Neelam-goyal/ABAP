  DATA : lv_vendor    TYPE lifnr.
  DATA : vfyear       TYPE i_materialdocumentheader_2-materialdocumentyear.
  DATA : lv_mm TYPE string,
         lv_yy TYPE string.

  DATA currenttime TYPE timestamp.
  GET TIME STAMP FIELD currenttime.
  DATA(time_factory) = cl_abap_timestamp_util=>get_instance( ).
  DATA(timezone) = time_factory->get_user_time_zone_string( ).
  CONVERT TIME STAMP currenttime TIME ZONE timezone INTO DATE DATA(currentdate).

  IF ( ( action = if_ex_mrm_check_invoice_cloud=>c_action_check ) OR
       ( action = if_ex_mrm_check_invoice_cloud=>c_action_post )  OR
       ( action = if_ex_mrm_check_invoice_cloud=>c_action_simulate ) ).
      " added by neelam / khusboo
    LOOP AT itemswithporeference INTO DATA(wa_item_qty).
      IF wa_item_qty-purchaseorder IS NOT INITIAL.

        " Select released CDS view for Goods Movement (check I_GoodsMovementCube is released)
        SELECT SINGLE totalgdsmvtqtyinbaseunit
          FROM i_goodsmovementcube
          WHERE purchaseorder     = @wa_item_qty-purchaseorder
            AND purchaseorderitem = @wa_item_qty-purchaseorderitem
            AND materialdocument  = @wa_item_qty-referencedocument
          INTO @DATA(lv_migoqty)  PRIVILEGED ACCESS.

        IF sy-subrc = 0 AND wa_item_qty-qtyinpurchaseorderpriceunit <> lv_migoqty.
          APPEND VALUE #(
            messagetype     = if_ex_mrm_check_invoice_cloud=>c_messagetype_error
            messageid       = 'MRM_BADI_CLOUD'
            messagenumber   = '001'
            messagevariable1 = |Invoice Receipt Qty <> GR Qty (PO { wa_item_qty-purchaseorder }/{ wa_item_qty-purchaseorderitem })|
          ) TO messages.
          RETURN.
        ENDIF.

      ENDIF.
    ENDLOOP.

