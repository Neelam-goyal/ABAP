lock master total etag PONumber
etag master Reqnr

authorization master ( instance )

{
  create;
  update;
  delete;

  field ( readonly, numbering : managed ) Cuuid;
  ////  field ( readonly ) Plant, Qty, Baseunit, PoQty, OrderQuantityUnit, TXZ01,PostingDate;// MaterialDoc;
  field ( readonly ) seqno,Plant, Qty, Baseunit, PoQty, OrderQuantityUnit, TXZ01, PostingDate, AcquisitionValue, CukyField;
  field ( mandatory ) Anlar, AssetDescription, AssetCategory, AcquisitionDate, ModelNumber, ObjectType
