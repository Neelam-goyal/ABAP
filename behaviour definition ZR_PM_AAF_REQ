  determination validate_field on modify { field PONumber, POItem, MaterialDoc, MaterialDocitem, Cuuid, Anlar; }
  determination set_defaults on modify { create; }
  determination update_revnr on modify { create;update; }

  side effects
  {
    // When MaterialDoc changes - refresh qty, date, description AND item table
    ////  field MaterialDoc affects field Qty,
    field MaterialDocitem affects field Qty,
    field PostingDate,
    field txz01,
    field PONumber,
    field PoQty,
    field Reqnr,
    field seqno,
    field AcquisitionValue,
    field CukyField,
    field AssetDescription,
    field AcquisitionDate,
    field ManufactureName,
    field VendorId,
    entity _Item;         //- THIS IS THE KEY FIX

    field POItem affects field PoQty, entity _Item;

    //" When PONumber changes - refresh everything including items
    field PONumber affects $self,
    entity _Item;        //  " <-- also add here
     field Reqnr affects entity _Item;
  }



  validation validate_fields on save
  { field
    Cuuid,  //new added
    Anlar,
    AssetCategory,
    FunctionalLocation,
    ObjectType,
    MdmaNumber,
    ModelNumber,
    SerialNumber,
    OrderComplete,
    ChemicalCheck,
    MechanicalCheck,
    FunctionalCheck,
    ElectricalCheck,
    Power,
    OperationManual,
    MnfMaintPlan,
    SchematicDrawing,
    TechnicalDatasheet,
    ServiceManual,
    LeasedServiceAgmt,
    PartList,
    AssetCriticality,
    MaintType,
    PmCycleMonths,
    EstRetirementDate,
    CalibrationCycle,
    PmStartDate,
    MaintWorkcenter,
    EstLifeSpanYears,
    WarrantyStart,
    WarrantyEnd,
    TypeOfService; }

  field ( readonly )

  WarrantyPeriod;


  field ( readonly )
  CostCenter,
  ManufacturePartNo;



  draft action Edit;
  draft action Activate ;
  draft action Discard;
  draft action Resume;

  draft determine action Prepare
  {
    validation validate_fields;             // Header's own validation
    validation AAF_REQ_I~validate_item_fields; // <--- ADD THIS LINE
  }
  association _Item { create; with draft; }


  mapping for zpm_aaf_req_rap corresponding
    {
      Cuuid              = cuuid;
      Reqnr              = reqnr;
      Revnr              = revnr;
      PONumber           = po_number;
      Anlar              = anlar;
      Asscat             = asscat;
      CukyField          = cuky_field;
      AcquisitionValue   = acquisition_value;
      MdmaNumber         = mdma_number;
      AssetDescription   = asset_description;
      AssetCategory      = asset_category;
      AcquisitionDate    = acquisition_date;
      ModelNumber        = model_number;
