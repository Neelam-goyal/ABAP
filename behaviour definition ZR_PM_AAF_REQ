      ObjectType         = object_type;
      SerialNumber       = serial_number;
      CostCenter         = cost_center;
      ManufactureName    = manufacture_name;
      ManufactureTel     = manufacture_tel;
      LocalVendor        = local_vendor;
      VendorTel          = vendor_tel;
      ManufacturePartNo  = manufacture_part_no;
      ManufactureAddress = manufacture_address;
      VendorId           = vendor_id;
      LocalVendorAddress = local_vendor_address;
      OrderComplete      = order_complete;
      ChemicalCheck      = chemical_check;
      MechanicalCheck    = mechanical_check;
      Remarks            = remarks;
      FunctionalCheck    = functional_check;
      ElectricalCheck    = electrical_check;
      Power              = power;
      OperationManual    = operation_manual;
      MnfMaintPlan       = mnf_maint_plan;
      SchematicDrawing   = schematic_drawing;
      TechnicalDatasheet = technical_datasheet;
      ServiceManual      = service_manual;
      LeasedServiceAgmt  = leased_service_agmt;
      PartList           = part_list;
      AssetCriticality   = asset_criticality;
      PmStartDate        = pm_start_date;
      WarrantyStart      = warranty_start;
      WarrantyEnd        = warranty_end;
      TypeOfService      = type_of_service;
      MaintType          = maint_type;
      MaintWorkcenter    = maint_workcenter;
      PmCycleMonths      = pm_cycle_months;
      EstLifeSpanYears   = est_life_span_years;
      WarrantyPeriod     = warranty_period;
      CalibrationCycle   = calibration_cycle;
      EstRetirementDate  = est_retirement_date;
      AssetNumber        = asset_number;
      AssetSubNumber     = asset_sub_number;
      EquipmentNumber    = equipment_number;
      POItem             = po_item;
      Qty                = migo_qty;
      Baseunit           = migo_qty_unit;
      PoQty              = po_qty;
      OrderQuantityUnit  = po_unit;
      PostingDate        = posting_date;
