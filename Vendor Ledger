FORM ALV_TOP_OF_LIST.
  SELECT SINGLE NAME1 INTO GV_VENDNAME FROM LFA1 WHERE LIFNR EQ SLIFNR-LOW.
  CONCATENATE 'Account : ' SLIFNR-LOW ' - ' GV_VENDNAME INTO GV_VENDNAME SEPARATED BY SPACE.
  SKIP 1.
  FORMAT COLOR 5 INVERSE ON.
  WRITE : /(120) gv_compname CENTERED.
  WRITE : /(120) 'Vendor Account Ledger' CENTERED.
  WRITE : /(120) GV_VENDNAME CENTERED.
  WRITE : /.
  WRITE : / 'Period From :',Sdate-LOW , ' To ', Sdate-HIGH .
  WRITE : /.
  CLEAR : GV_VENDNAME.
ENDFORM .

