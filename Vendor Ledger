* *-------------------------------------------------------------------*
*       FORM ALV_END_OF_LIST                                          *
*---------------------------------------------------------------------*
*       ........                                                      *
*---------------------------------------------------------------------*
FORM ALV_END_OF_LIST.
*  DATA : LV_TOTCLAMT   LIKE BAPI3006_4-BALANCE,
*         LV_OPBAL      LIKE BAPI3006_4-BALANCE,
*         LV_CLBAL      LIKE BAPI3006_4-BALANCE,
*         LV_OPBALSG(2) TYPE C,
*         LV_CLBALSG(2) TYPE C.
*
*  FIELD-SYMBOLS : <LFS_OPENBAL> TYPE ANY.
*
*  CLEAR : CLOSEBAL.
*  READ TABLE OPENBAL ASSIGNING <LFS_OPENBAL> WITH KEY LIFNR = SLIFNR-LOW.
*  IF SY-SUBRC = 0.
*     WOPENBAL = <LFS_OPENBAL>.
*     LV_OPBALP = WOPENBAL-HSL - WOPENBAL-CSL .
*
*     LV_TOTCLAMT = ( LV_OPBALP + LV_TOTDBAMT ) - LV_TOTCRAMT.
*
*     IF LV_OPBALP GE 0.
*        LV_OPBALSG = 'Dr'.
*        LV_OPBAL = LV_OPBALP.
*     ELSE.
*        LV_OPBALSG = 'Cr'.
*        LV_OPBAL = LV_OPBALP * '-1'.
*     ENDIF.
*
*     IF LV_TOTCLAMT GE 0.
*        LV_CLBALSG = 'Dr'.
*        LV_CLBAL = LV_TOTCLAMT.
*     ELSE.
*        LV_CLBALSG = 'Cr'.
*        LV_CLBAL = LV_TOTCLAMT * '-1'.
*     ENDIF.
*
*     SKIP 1.
*     FORMAT COLOR 5 INVERSE ON.
*
*     WRITE : /40 'Op. Balance  : ',LV_OPBAL    DECIMALS 2,LV_OPBALSG .
*     WRITE : /40 'Total Debit  : ',LV_TOTDBAMT DECIMALS 2.
*     WRITE : /40 'Total Credit : ',LV_TOTCRAMT DECIMALS 2.
*     WRITE : /40 '----------------------------------------------------'.
*     WRITE : /40 'Cl. Balance  : ',LV_CLBAL    DECIMALS 2,LV_CLBALSG.
*     WRITE : /40 '----------------------------------------------------'.
*     WRITE : /.
*  ENDIF.
ENDFORM .

