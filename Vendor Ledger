*&      Form  GET_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM get_data.
  IF p_amtlc = 'X'.
    lv_curr = 'X'.
  ELSEIF p_amtfc = 'X'.
    lv_curr = 'Y'.
  ENDIF.
  CALL FUNCTION 'Z_FI_VENDOR_BAL'
    EXPORTING
      sbukrs  = sbukrs
      fromdt  = sdate-low
      todt    = sdate-high
      lv_curr = lv_curr
      customer = lv_c
    IMPORTING
      return  = return
    TABLES
      slifnr  = slifnr
      sprctr  = sprctr
      openbal = openbal
      tacdoca = tacdoca
      sumskz  = sumskz.


*  SELECT rclnt rldnr rbukrs gjahr belnr docln ryear rtcur racct rcntr prctr hsl drcrk budat bldat blart zuonr bschl sgtxt lifnr kunnr
*         koart umskz augdt augbl werks wsl ktosl FROM acdoca INTO TABLE tacdoca2 FOR ALL ENTRIES IN tacdoca WHERE rldnr = '0L'
*         AND rbukrs = sbukrs
*         AND belnr  = tacdoca-belnr
*         AND budat  IN sdate
*         AND umskz IN sumskz.
*         and umskz in zumskz.

  SELECT bukrs as rbukrs gjahr belnr docln gjahr as ryear  racct rcntr prctr hsl drcrk budat bldat blart zuonr bschl sgtxt lifnr kunnr
         koart umskz augdt augbl werks wsl ktosl FROM bseg INTO TABLE tacdoca2 FOR ALL ENTRIES IN tacdoca WHERE rldnr = '0L'
         AND rbukrs = sbukrs
         AND belnr  = tacdoca-belnr
         AND budat  IN sdate
         AND umskz IN sumskz.


  IF sy-subrc IS INITIAL.
    REFRESH lt_acdoca_tds.
    lt_acdoca_tds = tacdoca2[].
    DELETE tacdoca2 WHERE koart <> 'K'.
    DELETE lt_acdoca_tds  WHERE ktosl <> 'WIT'.
    SORT lt_acdoca_tds BY rbukrs
                          belnr
                          gjahr
                          prctr.
    SELECT * FROM t003t INTO TABLE lt_t003t FOR ALL ENTRIES IN tacdoca2 WHERE spras = sy-langu AND blart = tacdoca2-blart.
  ENDIF.

  SELECT lifnr name1 FROM lfa1 INTO TABLE tlfa1 WHERE  lifnr IN slifnr and KTOKK = 'YEMP'.
  SELECT kostl ltext FROM cskt INTO TABLE lt_cskt FOR ALL ENTRIES IN tacdoca WHERE spras = 'E' AND kokrs = 'CDBG' AND kostl = tacdoca-rcntr.
  IF tacdoca IS NOT INITIAL.
    SELECT bukrs
           belnr
           gjahr
           bldat
           budat
           cpudt
           xblnr
           bktxt FROM bkpf INTO TABLE tbkpf
           FOR ALL ENTRIES IN tacdoca
           WHERE bukrs = sbukrs
           AND   belnr = tacdoca-belnr
           AND   gjahr = tacdoca-gjahr.

    IF tacdoca2 IS NOT INITIAL.
    ENDIF.

    SELECT * FROM skat INTO TABLE tskat FOR ALL ENTRIES IN tacdoca WHERE saknr = tacdoca-racct.
    SELECT * FROM skat APPENDING TABLE tskat FOR ALL ENTRIES IN tacdoca2 WHERE saknr = tacdoca2-racct.
    SELECT * FROM cepct INTO TABLE tcepct FOR ALL ENTRIES IN tacdoca WHERE prctr = tacdoca-prctr.

  ENDIF.

  IF tacdoca IS NOT INITIAL.
    SELECT * FROM t074t INTO TABLE tt074t FOR ALL ENTRIES IN tacdoca WHERE spras = 'E' AND koart = tacdoca-koart AND shbkz = tacdoca-umskz.
  ENDIF.

  IF tacdoca2 IS NOT INITIAL.
    SELECT * FROM t074t APPENDING TABLE tt074t FOR ALL ENTRIES IN tacdoca2 WHERE spras = 'E' AND   koart = tacdoca2-koart AND   shbkz = tacdoca2-umskz.
    SELECT kostl ltext FROM cskt INTO TABLE lt_cskt2 FOR ALL ENTRIES IN tacdoca2 WHERE spras = 'E' AND kokrs = 'CDBG' AND kostl = tacdoca2-rcntr.
  ENDIF.

  SELECT SINGLE werks INTO gv_plant FROM bseg WHERE bukrs EQ sbukrs AND werks <> ''.
  SELECT SINGLE name1, name2 FROM t001w INTO @DATA(wa_comp_name) WHERE werks EQ @gv_plant.
  CONCATENATE wa_comp_name-name1 wa_comp_name-name2 INTO gv_compname SEPARATED BY space.
  TRANSLATE gv_compname TO UPPER CASE.

ENDFORM.

*&---------------------------------------------------------------------*
*&      Form  FINAL_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM final_data.
  " SORT TACDOCA BY LIFNR PRCTR+0(4) BUDAT BELNR ."DESCENDING.

  DATA t_tmp  TYPE TABLE OF zacdoca.
  DATA p_tmp  TYPE TABLE OF zacdoca.
  DATA w_tmp  TYPE zacdoca.
  DATA lv_tmp TYPE i.

  FIELD-SYMBOLS <lfs_openbal> TYPE zlifnrbal.

  SORT tacdoca BY lifnr
                  budat
                  belnr. " DESCENDING.
  t_tmp[] = tacdoca[].
  p_tmp[] = tacdoca[].
  DELETE ADJACENT DUPLICATES FROM t_tmp COMPARING lifnr budat belnr.

  REFRESH lt_openbal[].
  lt_openbal[] = openbal[].
  SORT openbal BY lifnr.

*  loop at t_tmp into w_tmp where blart = 'KZ' or blart = 'ZP'.
*    lv_tmp = 1.
*    loop at tacdoca into wacdoca where belnr = w_tmp-belnr and gjahr = w_tmp-gjahr.
*      wacdoca-srno = lv_tmp.
*      lv_tmp += 1.
*      modify tacdoca from wacdoca.
*    endloop.
*  endloop.

*  delete tacdoca where srno > 1 and ( blart = 'KZ' or blart = 'ZP' ).
  if R_CLEAR eq ''.
     delete tacdoca where blart = 'AB' .
  endif.

  LOOP AT tacdoca INTO wacdoca WHERE blart = 'KZ' OR blart = 'ZP'.
*    wacdoca-hsl = 0.
*    loop at p_tmp into w_tmp where belnr = wacdoca-belnr and gjahr = wacdoca-gjahr.
*      wacdoca-hsl += w_tmp-hsl.
*    endloop.
    IF wacdoca-hsl > 0.
      wacdoca-drcrk = 'S'.
    ELSE.
      wacdoca-drcrk = 'H'.
    ENDIF.
    MODIFY tacdoca FROM wacdoca.
  ENDLOOP.

  LOOP AT tacdoca INTO wacdoca WHERE budat IN sdate AND koart = 'K'.
    IF vendor <> wacdoca-lifnr.
      CLEAR closebal.
      READ TABLE openbal ASSIGNING <lfs_openbal> WITH KEY lifnr = wacdoca-lifnr.
      IF sy-subrc = 0.
        wopenbal = <lfs_openbal>.
        wfinal-openbal = wopenbal-hsl.
      ENDIF.
    ENDIF.

    wfinal-rbukrs = wacdoca-rbukrs.
    wfinal-gjahr  = wacdoca-gjahr.
    wfinal-belnr  = wacdoca-belnr.
    wfinal-werks  = wacdoca-prctr+0(4).
    IF wacdoca-drcrk = 'H'.
      wfinal-shkzg = 'CR'.
    ELSEIF wacdoca-drcrk = 'S'.
      wfinal-shkzg = 'DR'.
    ENDIF.
    belnr = wacdoca-belnr.
    READ TABLE tbkpf INTO wbkpf WITH KEY belnr = wacdoca-belnr
                                         budat = wacdoca-budat.
    IF sy-subrc = 0.
      wfinal-xblnr = wbkpf-xblnr.
      wfinal-bktxt = wbkpf-bktxt.
      wfinal-augdt = wbkpf-cpudt.
    ENDIF.
    READ TABLE tlfa1 INTO wlfa1 WITH KEY lifnr = wacdoca-lifnr.
    IF sy-subrc = 0.
      wfinal-name1 = wlfa1-name1.
    ENDIF.
    wfinal-ryear = wacdoca-ryear.
    wfinal-rtcur = wacdoca-rtcur.
    wfinal-racct = wacdoca-racct.
    READ TABLE tskat INTO wskat WITH KEY saknr = wacdoca-racct.
    IF sy-subrc = 0.
      wfinal-txt50 = wskat-txt50.
    ENDIF.
    wfinal-rcntr = wacdoca-rcntr.
    wfinal-prctr = wacdoca-prctr.
    prctr        = wacdoca-prctr.
    vendor       = wacdoca-lifnr.
    IF lv_curr = 'Y'.
      wacdoca-hsl = wacdoca-wsl.
    ENDIF.

    wfinal-hsldeb = wacdoca-hsl.
    READ TABLE tt074t INTO wt074t WITH KEY koart = wacdoca-koart
                                           shbkz = wacdoca-umskz.
    IF sy-subrc = 0.
      wfinal-ltext1 = wt074t-ltext.
    ENDIF.
    wfinal-budat = wacdoca-budat.
    wfinal-bldat = wacdoca-bldat.
    wfinal-blart = wacdoca-blart.

    CLEAR lw_t003t.
    READ TABLE lt_t003t INTO lw_t003t WITH KEY blart = wacdoca-blart.
    IF sy-subrc IS INITIAL.
      wfinal-blart_des = lw_t003t-ltext.
    ENDIF.

    wfinal-zuonr = wacdoca-zuonr.
    wfinal-bschl = wacdoca-bschl.
    wfinal-sgtxt = wacdoca-sgtxt.
    IF wacdoca-koart = 'K'.
      wfinal-lifnr = wacdoca-lifnr.
    ENDIF.

    wfinal-koart = wacdoca-koart.
    IF wacdoca-koart = 'D'.
      wfinal-kunnr = wacdoca-kunnr.
    ENDIF.
    wfinal-umskz = wacdoca-umskz.
    wfinal-augbl = wacdoca-augbl.
    closebal     += wfinal-openbal + wacdoca-hsl.
    wfinal-closebal = closebal.

*    <lfs_openbal>-hsl = closebal.

    IF wacdoca-drcrk = 'H'.
      wfinal-hsldeb = wacdoca-hsl.
    ENDIF.
    READ TABLE lt_cskt INTO DATA(wa_cskt) WITH KEY kostl = wfinal-rcntr.
    IF sy-subrc = 0.
      wfinal-ltext = wa_cskt-ltext.
      CLEAR wa_cskt.
    ENDIF.
    CLEAR lw_acdoca_tds.
    READ TABLE lt_acdoca_tds INTO lw_acdoca_tds WITH KEY rbukrs = wacdoca-rbukrs
                                                         belnr  = wacdoca-belnr
                                                         gjahr  = wacdoca-gjahr.

    IF sy-subrc IS INITIAL.
      IF lv_curr = 'Y'.
        wfinal-tds = lw_acdoca_tds-wsl.
      ELSE.
        wfinal-tds = lw_acdoca_tds-hsl.
      ENDIF.
    ENDIF.
    APPEND wfinal TO tfinal.
    CLEAR wfinal.
    CLEAR wlfa1.
    CLEAR wskat.
    CLEAR wt074t.

    LOOP AT tacdoca2 INTO wacdoca2 WHERE     belnr  = belnr
                                         AND docln <> wacdoca-docln
                                         AND budat IN sdate
                                         AND koart <> 'K'.
      wfinal-rbukrs = wacdoca2-rbukrs.
      wfinal-gjahr  = wacdoca2-gjahr.
      wfinal-belnr  = wacdoca2-belnr.
      wfinal-xblnr  = wbkpf-xblnr.
      wfinal-bktxt  = wbkpf-bktxt.
      wfinal-augdt  = wbkpf-cpudt.
      wfinal-ryear  = wacdoca2-ryear.
      wfinal-rtcur  = wacdoca2-rtcur.
      CLEAR lw_acdoca_tds.
      READ TABLE lt_acdoca_tds INTO lw_acdoca_tds WITH KEY rbukrs = wacdoca2-rbukrs
                                                           belnr  = wacdoca2-belnr
                                                           gjahr  = wacdoca2-gjahr.
      IF sy-subrc IS INITIAL.
        IF lv_curr = 'Y'.
          wfinal-tds = lw_acdoca_tds-wsl.
        ELSE.
          wfinal-tds = lw_acdoca_tds-hsl.
        ENDIF.
      ENDIF.

      IF wacdoca2-drcrk = 'H'.
        wfinal-shkzg = 'CR'. " wacdoca-drcrk.
      ELSEIF wacdoca2-drcrk = 'S'.
        wfinal-shkzg = 'DR'.
      ENDIF.

      READ TABLE tt074t INTO wt074t WITH KEY koart = wacdoca2-koart
                                             shbkz = wacdoca2-umskz.
      IF sy-subrc = 0.
        wfinal-ltext1 = wt074t-ltext.
      ENDIF.
      READ TABLE tskat INTO wskat WITH KEY saknr = wacdoca2-racct.
      IF sy-subrc = 0.
        wfinal-txt50 = wskat-txt50.
      ENDIF.
      wfinal-racct = wacdoca2-racct.
      wfinal-rcntr = wacdoca2-rcntr.
      wfinal-prctr = wacdoca2-prctr.

      IF lv_curr = 'Y'.
        wacdoca2-hsl = wacdoca2-wsl.
      ENDIF.

      IF wacdoca2-drcrk = 'S'.
        wfinal-hsldeb = wacdoca2-hsl.
      ELSEIF wacdoca2-drcrk = 'H'.
        wfinal-hsldeb = wacdoca2-hsl.
      ENDIF.
      READ TABLE tlfa1 INTO wlfa1 WITH KEY lifnr = wacdoca2-lifnr.
      IF sy-subrc = 0.
        wfinal-name1 = wlfa1-name1.
      ENDIF.
      wfinal-budat = wacdoca2-budat.
      wfinal-bldat = wacdoca2-bldat.
      wfinal-blart = wacdoca2-blart.

      CLEAR lw_t003t.
      READ TABLE lt_t003t INTO lw_t003t WITH KEY blart = wacdoca2-blart.
      IF sy-subrc IS INITIAL.
        wfinal-blart_des = lw_t003t-ltext.
      ENDIF.
      wfinal-zuonr = wacdoca2-zuonr.
      wfinal-bschl = wacdoca2-bschl.
      wfinal-sgtxt = wacdoca2-sgtxt.
      wfinal-lifnr = wacdoca2-lifnr.
      wfinal-koart = wacdoca2-koart.
      IF wacdoca2-koart = 'D'.
        wfinal-kunnr = wacdoca2-kunnr.
      ENDIF.
      wfinal-umskz = wacdoca2-umskz.
      wfinal-augbl = wacdoca2-augbl.
      READ TABLE lt_cskt2 INTO DATA(wa_cskt2) WITH KEY kostl = wfinal-rcntr.
      IF sy-subrc = 0.
        wfinal-ltext = wa_cskt2-ltext.
        CLEAR wa_cskt2.
      ENDIF.
      APPEND wfinal TO tfinal.
      DELETE tacdoca2.
      CLEAR wacdoca2.
      CLEAR wfinal.
      CLEAR wlfa1.
      CLEAR wskat.
    ENDLOOP.
    CLEAR wfinal.
    CLEAR wacdoca.
    CLEAR wacdoca2.
    CLEAR belnr.
  ENDLOOP.
  "
  CLEAR closebal.
  READ TABLE openbal ASSIGNING <lfs_openbal> WITH KEY lifnr = slifnr-low.
  IF sy-subrc = 0.
    IF wopenbal-hsl IS INITIAL.
      wopenbal = <lfs_openbal>.
      wa_fin-clblamt = abs( wopenbal-hsl - wopenbal-csl ).
    ENDIF.
    wa_fin-color   = 'C51'.
    wa_fin-budat   = sdate-low.
    wa_fin-sgtxt   = 'Opening Balance'.
    wa_fin-clblamt = abs( wopenbal-hsl ).
*    if wfinal-closebal > 0.
    IF wopenbal-hsl GT 0.
      wa_fin-drcrt = 'Dr'.
    ELSE.
      wa_fin-drcrt = 'Cr'.
    ENDIF.
    APPEND wa_fin TO it_fin.
    CLEAR wa_fin.
  ENDIF.

  LOOP AT tfinal INTO wfinal.
    wa_fin-bukrs = wfinal-rbukrs.
    wa_fin-belnr = wfinal-belnr.
    wa_fin-gjahr = wfinal-gjahr.
    wa_fin-blart = wfinal-blart.
    wa_fin-budat = wfinal-budat.

    wa_fin-bldat = wfinal-bldat.
    wa_fin-xblnr = wfinal-xblnr.
    wa_fin-prctr = wfinal-prctr.

    SELECT SINGLE
    FROM acdoca AS ze
    INNER JOIN acdoca AS re ON
      re~awref = ze~awref AND
      re~gjahr = ze~gjahr AND
      re~rbukrs = ze~rbukrs AND
      re~ebeln IS NOT INITIAL AND
      re~blart = char`RE`
    FIELDS re~sgtxt
    WHERE
      ze~belnr = @wa_fin-belnr AND
      ze~gjahr = @wa_fin-gjahr AND
      ze~blart = @wa_fin-blart AND
      @wa_fin-blart = char`ZE` AND
      ze~rbukrs = @wa_fin-bukrs
    INTO @wa_fin-sgtxt.
    IF sy-subrc <> 0.
      wa_fin-sgtxt = wfinal-sgtxt.
    ENDIF.
    IF wfinal-hsldeb > 0.
      wa_fin-dramt = abs( wfinal-hsldeb ).
    ELSEIF wfinal-hsldeb < 0.
      wa_fin-cramt = abs( wfinal-hsldeb ).
    ENDIF.
    wa_fin-clblamt = abs( wfinal-closebal ).

    IF wfinal-tds IS INITIAL.
      SELECT SINGLE dmbtr FROM bseg INTO wa_fin-tdsam
      WHERE belnr = wa_fin-belnr AND bukrs = wa_fin-bukrs AND gjahr = wa_fin-gjahr AND h_blart = 'KZ' AND hkont = '0001460018'.
    ELSE.
      wa_fin-tdsam   = abs( wfinal-tds ).
    ENDIF.
    lv_totdbamt    += wa_fin-dramt.
    lv_totcramt    += wa_fin-cramt.
    IF wfinal-closebal > 0.
      wa_fin-drcrt = 'Dr'.
    ELSE.
      wa_fin-drcrt = 'Cr'.
    ENDIF.
    APPEND wa_fin TO it_fin.
    CLEAR wa_fin.
  ENDLOOP.
ENDFORM.

