  CASE SELFIELD-SEL_TAB_FIELD.
    WHEN 'IT_FIN-BELNR'.
      SET PARAMETER ID 'BUK'  FIELD IT_FIN-BUKRS.
      SET PARAMETER ID 'BLN'  FIELD IT_FIN-BELNR.
      SET PARAMETER ID 'GJR'  FIELD IT_FIN-GJAHR.
      CALL TRANSACTION 'FB03' AND SKIP FIRST SCREEN.
  ENDCASE.
