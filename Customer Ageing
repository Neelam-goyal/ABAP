*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM check_days_breakup .
  IF p_days5 IS NOT INITIAL AND p_days4 IS INITIAL.
    MESSAGE e000 WITH 'You Can Not Break The Serial' 'Fill The 4th Days'.
  ENDIF.
  IF p_days4 IS NOT INITIAL AND p_days3 IS INITIAL.
    MESSAGE e000 WITH 'You Can Not Break The Serial' 'Fill The 3rd Days'.
  ENDIF.
  IF p_days3 IS NOT INITIAL AND p_days2 IS INITIAL.
    MESSAGE e000 WITH 'You Can Not Break The Serial' 'Fill The 2nd Days'.
  ENDIF.
  IF p_days2 IS NOT INITIAL AND p_days1 IS INITIAL.
    MESSAGE e000 WITH 'You Can Not Break The Serial' 'Fill The 1st Days'.
  ENDIF.

  IF p_days1 GE p_days2.
    IF p_days2 IS NOT INITIAL.
      MESSAGE e000 WITH 'Days Of 2nd Term Should Be Greater Then 1st'.
    ENDIF.
  ELSEIF p_days2 GE p_days3 .
    IF p_days3 IS NOT INITIAL.
      MESSAGE e000 WITH 'Days Of 3rd Term Should Be Greater Then 2nd'.
    ENDIF.
  ELSEIF p_days3 GE p_days4.
    IF p_days4 IS NOT INITIAL.
      MESSAGE e000 WITH 'Days Of 4th Term Should Be Greater Then 3rd'.
    ENDIF.
  ELSEIF p_days4 GE p_days5.
    IF p_days5 IS NOT INITIAL.
      MESSAGE e000 WITH 'Days Of 5th Term Should Be Greater Then 4th'.
    ENDIF.
**  elseif p_days5 ge p_days6.
**    if p_days6 is not initial.
**      message e000 with 'Days Of 6th Term Should Be Greater Then 5th'.
**    endif.
**  elseif p_days6 ge p_days7.
**    if p_days7 is not initial.
**      message e000 with 'Days Of 7th Term Should Be Greater Then 6th'.
**    endif.
**  elseif p_days7 ge p_days8.
**    if p_days8 is not initial.
**      message e000 with 'Days Of 8th Term Should Be Greater Then 7th'.
**    endif.
  ENDIF.
ENDFORM. " CHECK_DAYS_BREAKUP
