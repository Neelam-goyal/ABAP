*&---------------------------------------------------------------------*
*& Form CALCULATE_DAYS1
*&---------------------------------------------------------------------*
*& text
*&---------------------------------------------------------------------*
*      -->P_GS_OUTPUT_DUEDT  text
*&---------------------------------------------------------------------*
form calculate_days1 using p_date.
  data: lv_diff  type p,
        lv_early type c.

  call function '/SDF/CMO_DATETIME_DIFFERENCE'
    exporting
      date1            = p_date
      date2            = p_budat
    importing
      datediff         = lv_diff
      earliest         = lv_early
    exceptions
      invalid_datetime = 1
      others           = 2.
  if sy-subrc <> 0.
    message id sy-msgid type sy-msgty number sy-msgno
            with sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.
  endif.

  if gs_output-osbal < 0.
    if gs_output-umskz is not initial.
      gs_output-advan = gs_output-osbal.
    else.
      gs_output-crbal = gs_output-osbal.
       endif.
  endif.

  if lv_early = 1 or lv_early = 0.
    if gs_output-osbal > 0.
      if lv_diff ge p_days0 and lv_diff le p_days1.
        gs_output-range1 = gs_output-osbal.
      elseif lv_diff gt p_days1 and lv_diff le p_days2.
        gs_output-range2 = gs_output-osbal.
      elseif lv_diff gt p_days2 and lv_diff le p_days3.
        gs_output-range3 = gs_output-osbal.
      elseif lv_diff gt p_days3 and lv_diff le p_days4.
        gs_output-range4 = gs_output-osbal.
      elseif lv_diff gt p_days4 and lv_diff le p_days5.
        gs_output-range5 = gs_output-osbal.
      elseif lv_diff gt p_days5 ."and lv_diff le p_days6.
        gs_output-range9 = gs_output-osbal.
**      elseif lv_diff gt p_days6 and lv_diff le p_days7.
**        gs_output-range7 = gs_output-osbal.
**      elseif lv_diff gt p_days7 and lv_diff le p_days8.
**        gs_output-range8 = gs_output-osbal.
**      elseif lv_diff gt p_days8.
**        gs_output-range9 = gs_output-osbal.
      endif.
    endif.
  elseif lv_early = 2.
    if gs_output-osbal > 0.
*      BREAK abap.
      gs_output-nodue = gs_output-osbal.
    endif.
  endif.
endform. " CALCULATE_DAYS


