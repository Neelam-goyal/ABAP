*&      Form  USER_COMMAND
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->R_UCOMM      text
*      -->RS_SELFIELD  text
*----------------------------------------------------------------------*
FORM user_command USING r_ucomm LIKE sy-ucomm
                        rs_selfield TYPE slis_selfield.
  TYPE-POOLS : rsds.
  DATA:lt_seltab TYPE TABLE OF rsparams,
       ls_seltab LIKE LINE OF lt_seltab.
  IF p_summ EQ 'X'.
    READ TABLE gt_output1 INTO gs_output1 INDEX rs_selfield-tabindex.
  ELSE.
    READ TABLE gt_output INTO gs_output INDEX rs_selfield-tabindex.
  ENDIF.
  CASE rs_selfield-fieldname.
    WHEN 'BELNR'.
      SET PARAMETER ID 'BLN' FIELD gs_output-belnr.
      SET PARAMETER ID 'GJR' FIELD gs_output-gjahr.
      SET PARAMETER ID 'BUK' FIELD gs_output-bukrs.
      CALL TRANSACTION 'FB03' AND SKIP FIRST SCREEN.
    WHEN 'BILLNO'.
      SET PARAMETER ID 'VF'  FIELD gs_output-billno.
      CALL TRANSACTION 'VF03' AND SKIP FIRST SCREEN.
    WHEN 'LIFNR'.
      IF p_summ EQ 'X'.
        ls_seltab-selname = 'BUKRS'.
        ls_seltab-kind = 'S'.
        ls_seltab-sign = 'I'.
        ls_seltab-option = 'EQ'.
        ls_seltab-low = gs_output1-bukrs.
        APPEND ls_seltab TO lt_seltab.
        CLEAR : ls_seltab.

        ls_seltab-selname = 'KD_LIFNR'.
        ls_seltab-kind = 'S'.
        ls_seltab-sign = 'I'.
        ls_seltab-option = 'EQ'.
        ls_seltab-low = gs_output1-lifnr.
        APPEND ls_seltab TO lt_seltab.
        CLEAR : ls_seltab.
      ELSE.
        ls_seltab-selname = 'BUKRS'.
        ls_seltab-kind = 'S'.
        ls_seltab-sign = 'I'.
        ls_seltab-option = 'EQ'.
        ls_seltab-low = gs_output-bukrs.
        APPEND ls_seltab TO lt_seltab.
        CLEAR : ls_seltab.

        ls_seltab-selname = 'KD_LIFNR'.
        ls_seltab-kind = 'S'.
        ls_seltab-sign = 'I'.
        ls_seltab-option = 'EQ'.
        ls_seltab-low = gs_output-lifnr.
        APPEND ls_seltab TO lt_seltab.
        CLEAR : ls_seltab.
      ENDIF.

      ls_seltab-selname = 'PA_STIDA'.
      ls_seltab-kind = 'S'.
      ls_seltab-sign = 'I'.
      ls_seltab-option = 'EQ'.
      ls_seltab-low = p_budat.
      APPEND ls_seltab TO lt_seltab.
      CLEAR : ls_seltab.

      IF p_ven = 'X'.
        ls_seltab-selname = 'X_APAR'.
        ls_seltab-kind = 'S'.
        ls_seltab-sign = 'I'.
        ls_seltab-option = 'EQ'.
        ls_seltab-low = 'X'.
        APPEND ls_seltab TO lt_seltab.
        CLEAR : ls_seltab.
      ENDIF.

      SET PARAMETER ID 'LIF' FIELD gs_output-lifnr.
      SET PARAMETER ID 'BUK' FIELD gs_output-bukrs.
      SUBMIT rfitemap
    WITH SELECTION-TABLE lt_seltab USING SELECTION-SCREEN 'CDBG' AND RETURN.

    WHEN OTHERS.
  ENDCASE.
  CLEAR gs_output.
ENDFORM. "USER_COMMAND
