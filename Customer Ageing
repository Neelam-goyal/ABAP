*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM calculate_days USING p_date.
  DATA: lv_diff  TYPE p,
        lv_early TYPE c.

**********Added by 2I:GS:23/04/2020(+)****************************************************************
  DATA: lv_begin  TYPE datum,
        lv_end    TYPE datum,
        lv_cal    TYPE p0001-begda,
        lv_middle TYPE p0001-begda,
        lv_days   TYPE t5a4a-dlydy,
        lv_month  TYPE t5a4a-dlymo,
        lv_year   TYPE t5a4a-dlyyr.

  DATA: lv_hdays TYPE t5a4a-dlydy,
        lv_wdays TYPE t5a4a-dlydy.

  DATA: lv_week TYPE scal-week,
        lv_mon  TYPE sy-datum,
        lv_sun  TYPE sy-datum.

  DATA: lv_wdiff  TYPE p,
        lv_wearly TYPE c.

  DATA: gv_diff  TYPE p,
        gv_early TYPE c.

  CLEAR: lv_begin, lv_end, lv_month, lv_year, lv_cal, lv_wdays, lv_hdays.

  IF r_dd = 'X'.
    SELECT SINGLE * FROM t052 INTO @DATA(ls_t052) WHERE zterm = @gs_output-zterm.
    IF ls_t052 IS NOT INITIAL.
      lv_days = ls_t052-ztag1.
    ENDIF.

    READ TABLE gt_lfb1 INTO DATA(ls_lfb1) WITH KEY lifnr = gs_output-lifnr
                                                   bukrs = gs_output-bukrs.
    IF sy-subrc = 0.
      gs_output-p_method = ls_lfb1-zwels.  "Payment method
      CALL FUNCTION 'HR_JP_MONTH_BEGIN_END_DATE'
        EXPORTING
          iv_date             = gs_output-bldat "p_date
        IMPORTING
          ev_month_begin_date = lv_begin
          ev_month_end_date   = lv_end.
    ENDIF.

    CLEAR:lv_hdays.
*  if ls_t052-ZLSCH = 'M'.
    IF ls_lfb1-zwels = 'M'.

********Half month logic(+)*********************************************
      lv_hdays = lv_days - 15.
********Half month logic(-)*********************************************

      CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
        EXPORTING
          date      = lv_end
          days      = lv_hdays "lv_Days "'45'
          months    = lv_month
          signum    = '+'
          years     = lv_year
        IMPORTING
          calc_date = lv_cal.
*    endif.

      CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
        EXPORTING
          date1            = lv_cal "p_budat "p_date
          date2            = p_budat "lv_cal "lv_end "p_budat
        IMPORTING
          datediff         = lv_diff
          earliest         = lv_early
        EXCEPTIONS
          invalid_datetime = 1
          OTHERS           = 2.
      IF sy-subrc <> 0.
        MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.

      ENDIF.

      gs_output-duedt = lv_cal.
      lv_flag = 'X'.
      CLEAR: lv_hdays.
**********Weekly(+)********************************************************
    ELSEIF ls_lfb1-zwels = 'W'.
      CALL FUNCTION 'GET_WEEK_INFO_BASED_ON_DATE'
        EXPORTING
          date   = gs_output-bldat "SY-DATUM
        IMPORTING
          week   = lv_week
          monday = lv_mon
          sunday = lv_sun.

********Half month logic(+)*********************************************
      CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
        EXPORTING
          date1            = lv_sun
          date2            = gs_output-bldat
        IMPORTING
          datediff         = lv_wdiff
          earliest         = lv_wearly
        EXCEPTIONS
          invalid_datetime = 1
          OTHERS           = 2.
      IF sy-subrc <> 0.
        MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.

      ENDIF.
      lv_wdays = lv_wdiff / 2.
      lv_hdays = lv_days - lv_wdays. "( lv_wdiff / 2 ).
********Half month logic(-)*********************************************

      CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
        EXPORTING
          date      = lv_sun
          days      = lv_hdays "lv_days "ls_t052-ZTAG1  "'45'
          months    = lv_month
          signum    = '+'
          years     = lv_year
        IMPORTING
          calc_date = lv_cal.
*    endif.

      CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
        EXPORTING
          date1            = lv_cal "p_budat "p_date
          date2            = p_budat "lv_cal "lv_end "p_budat
        IMPORTING
          datediff         = lv_diff
          earliest         = lv_early
        EXCEPTIONS
          invalid_datetime = 1
          OTHERS           = 2.
      IF sy-subrc <> 0.
        MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.

      ENDIF.

      gs_output-duedt = lv_cal.
      lv_flag = 'X'.
      CLEAR: lv_hdays, lv_wdays.
**********Weekly(-)********************************************************

**********Fornigntly(+)****************************************************
    ELSEIF ls_lfb1-zwels = 'F'.

      CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
        EXPORTING
          date      = lv_begin
          days      = '14' "'45'
          months    = lv_month
          signum    = '+'
          years     = lv_year
        IMPORTING
          calc_date = lv_middle.

      IF gs_output-bldat LE lv_middle.

********Half month logic(+)*********************************************
        lv_hdays = lv_days - 7.
********Half month logic(-)*********************************************

        CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
          EXPORTING
            date      = lv_middle
            days      = lv_hdays "lv_days "ls_t052-ZTAG1  "'45'
            months    = lv_month
            signum    = '+'
            years     = lv_year
          IMPORTING
            calc_date = lv_cal.

        CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
          EXPORTING
            date1            = lv_cal "p_budat "p_date
            date2            = p_budat "lv_cal "lv_end "p_budat
          IMPORTING
            datediff         = lv_diff
            earliest         = lv_early
          EXCEPTIONS
            invalid_datetime = 1
            OTHERS           = 2.
        IF sy-subrc <> 0.
          MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                  WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.

        ENDIF.

        gs_output-duedt = lv_cal.
        lv_flag = 'X'.
        CLEAR: lv_hdays.
      ELSE.

********Half month logic(+)*********************************************
        lv_hdays = lv_days - 7.
********Half month logic(-)*********************************************

        CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
          EXPORTING
            date      = lv_end
            days      = lv_hdays "lv_days "ls_t052-ZTAG1  "'45'
            months    = lv_month
            signum    = '+'
            years     = lv_year
          IMPORTING
            calc_date = lv_cal.

        CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
          EXPORTING
            date1            = lv_cal "p_budat "p_date
            date2            = p_budat "lv_cal "lv_end "p_budat
          IMPORTING
            datediff         = lv_diff
            earliest         = lv_early
          EXCEPTIONS
            invalid_datetime = 1
            OTHERS           = 2.
        IF sy-subrc <> 0.
          MESSAGE ID sy-msgid TYPE sy-msgty NUMBER sy-msgno
                  WITH sy-msgv1 sy-msgv2 sy-msgv3 sy-msgv4.

        ENDIF.

        gs_output-duedt = lv_cal.
        lv_flag = 'X'.
        CLEAR: lv_hdays.
      ENDIF.


**********Fornigntly(-)****************************************************
    ELSE.
      CALL FUNCTION '/SDF/CMO_DATETIME_DIFFERENCE'
        EXPORTING
          date1            = p_date
          date2            = p_budat
