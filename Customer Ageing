**      lv_days = p_days7.
**    endif.
**
**    if p_days8 is not initial.
**      clear lv_days.
**      lv_days = p_days7 + 1.
**      gs_fcat-fieldname = 'RANGE8'.
**      concatenate lv_days 'To' p_days8 'Days' into gs_fcat-seltext_l
**                                              separated by space.
**      gs_fcat-ddictxt = 'L'.
**      append gs_fcat to gt_fcat.
**      clear  gs_fcat.
**      lv_days = p_days8.
**    endif.

    gs_fcat-fieldname = 'RANGE9'.
    CONCATENATE 'More Than' lv_days 'Days' INTO gs_fcat-seltext_l
                                           SEPARATED BY space.
    CONCATENATE 'More Than' lv_days 'Days' INTO days5 SEPARATED BY space.
    gs_fcat-ddictxt = 'L'.
    gs_fcat-decimals_out = '2'.
    gs_fcat-no_zero = 'X'.
    APPEND gs_fcat TO gt_fcat.
    CLEAR  gs_fcat.

    gs_fcat-fieldname = 'NODUE'.
    gs_fcat-seltext_l = 'Not Due'.
    gs_fcat-ddictxt = 'L'.
    gs_fcat-decimals_out = '2'.
    gs_fcat-no_zero = 'X'.
    APPEND gs_fcat TO gt_fcat.
    CLEAR  gs_fcat.

*    gs_fcat-fieldname = 'ZSS'.  """"" ADDED BY VD
*    gs_fcat-seltext_l = 'ACT Due date'.
*    gs_fcat-ddictxt = 'L'.
*    APPEND gs_fcat TO gt_fcat.
*    CLEAR  gs_fcat.

    gs_fcat-fieldname = 'WRANGE1'.
    CONCATENATE p_weeks0 'To' p_weeks1 'Days' INTO gs_fcat-seltext_l
                                            SEPARATED BY space.
    gs_fcat-ddictxt = 'L'.
    gs_fcat-decimals_out = '2'.
    gs_fcat-no_zero = 'X'.
    APPEND gs_fcat TO gt_fcat.
    CLEAR  gs_fcat.
    gv_days = p_weeks1.

    IF p_weeks2 IS NOT INITIAL.
      CLEAR gv_days.
      gv_days = p_weeks1 + 1.
      gs_fcat-fieldname = 'WRANGE2'.
      CONCATENATE gv_days 'To' p_weeks2 'Days' INTO gs_fcat-seltext_l
                                              SEPARATED BY space.
      gs_fcat-ddictxt = 'L'.
      gs_fcat-decimals_out = '2'.
      gs_fcat-no_zero = 'X'.
      APPEND gs_fcat TO gt_fcat.
      CLEAR  gs_fcat.
      gv_days = p_weeks2.
    ENDIF.

    IF p_weeks3 IS NOT INITIAL.
      CLEAR gv_days.
      gv_days = p_weeks2 + 1.
      gs_fcat-fieldname = 'WRANGE3'.
      CONCATENATE gv_days 'To' p_weeks3 'Days' INTO gs_fcat-seltext_l
                                              SEPARATED BY space.
      gs_fcat-ddictxt = 'L'.
      gs_fcat-decimals_out = '2'.
      gs_fcat-no_zero = 'X'.
      APPEND gs_fcat TO gt_fcat.
      CLEAR  gs_fcat.
      gv_days = p_weeks3.
    ENDIF.

    IF p_weeks4 IS NOT INITIAL.
      CLEAR gv_days.
      gv_days = p_weeks3 + 1.
      gs_fcat-fieldname = 'WRANGE4'.
      CONCATENATE gv_days 'To' p_weeks4 'Days' INTO gs_fcat-seltext_l
                                              SEPARATED BY space.
      gs_fcat-ddictxt = 'L'.
      gs_fcat-decimals_out = '2'.
      gs_fcat-no_zero = 'X'.
      APPEND gs_fcat TO gt_fcat.
      CLEAR  gs_fcat.
      gv_days = p_weeks4.
    ENDIF.
    gs_fcat-fieldname = 'WRANGE6'.
    CONCATENATE 'More Than' gv_days 'Days' INTO gs_fcat-seltext_l
                                           SEPARATED BY space.
    gs_fcat-ddictxt = 'L'.
    gs_fcat-decimals_out = '2'.
    gs_fcat-no_zero = 'X'.
    APPEND gs_fcat TO gt_fcat.
    CLEAR:  gs_fcat, gv_days.
  ENDIF.
  gs_fcat-fieldname = 'OSBAL_1'.
  gs_fcat-seltext_l = 'Total Due'.
  gs_fcat-ddictxt = 'L'.
  gs_fcat-decimals_out = '2'.
  gs_fcat-no_zero = 'X'.
  APPEND gs_fcat TO gt_fcat.
  CLEAR  gs_fcat.
  IF p_summ NE 'X'.
    gs_fcat-fieldname = 'CAL_YEAR'.
    gs_fcat-seltext_l = 'Month & Year'.
    gs_fcat-ddictxt = 'L'.
    APPEND gs_fcat TO gt_fcat.
    CLEAR  gs_fcat.
  ENDIF.
ENDFORM. " BUILD_FCAT
