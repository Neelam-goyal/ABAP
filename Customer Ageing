*----------------------------------------------------------------------*
FORM get_data .


  CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
    EXPORTING
      text = 'Fetching opened items for Vendor...'.
  REFRESH gt_lfb1.
  SELECT * FROM lfb1 INTO TABLE gt_lfb1 WHERE bukrs IN s_bukrs AND lifnr IN s_lifnr." and brsch in s_BRSCH." and mindk in s_mindk.

  " Selecting the opened items of Vendor data
  SELECT   a~bukrs a~lifnr a~budat a~gjahr a~belnr a~buzei a~sgtxt a~bldat a~xblnr  a~blart a~augdt  a~zfbdt a~zterm a~zbd1t
           a~zbd2t a~zbd2t a~rebzg a~rebzt a~augbl a~umskz a~gkont a~hkont
           b~bschl b~drcrk b~hsl b~tsl b~rwcur c~bpkind INTO CORRESPONDING FIELDS OF TABLE gt_bsik
           FROM bsik AS a  INNER JOIN faglflexa AS b
           ON a~belnr = b~belnr  AND a~buzei = b~buzei AND a~gjahr = b~ryear AND a~bukrs = b~rbukrs
           INNER JOIN  but000 AS c
           ON a~lifnr = c~partner
           WHERE bukrs IN s_bukrs AND a~budat <= p_budat
           AND a~lifnr IN s_lifnr AND b~rldnr EQ p_rldnr AND c~bpkind IN s_bpkind AND  a~hkont IN s_hkont AND a~umskz IN s_umskz.

  CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
    EXPORTING
      text = 'Fetching cleared items for Vendor... '.
*  BREAK abap.
  "Selecting the cleared items of Vendor data
*  if p_budat < sy-datum.

  SELECT   a~bukrs a~lifnr a~budat a~gjahr a~belnr a~buzei a~sgtxt a~bldat a~xblnr  a~blart a~augdt  a~zfbdt a~zterm a~zbd1t
           a~zbd2t a~zbd2t a~rebzg a~rebzt a~augbl a~umskz a~gkont a~hkont
           b~bschl b~drcrk b~hsl b~tsl b~rwcur c~bpkind APPENDING CORRESPONDING FIELDS OF TABLE gt_bsik
           FROM bsak AS a  INNER JOIN faglflexa AS b
           ON a~belnr = b~belnr AND a~buzei = b~buzei AND a~gjahr = b~ryear AND a~bukrs = b~rbukrs
            INNER JOIN  but000 AS c
         ON a~lifnr = c~partner
            WHERE bukrs IN s_bukrs AND a~augdt GT p_budat AND a~budat LE p_budat
           AND a~lifnr IN s_lifnr AND b~rldnr EQ p_rldnr AND c~bpkind IN s_bpkind AND a~hkont IN s_hkont AND a~umskz IN s_umskz.
*  endif.
* ***********************************************************************************************BOC by Rajan/Lalit Upreti.
  LOOP AT gt_bsik INTO DATA(gs_bsk).
    gs_upd-bukrs  = gs_bsk-bukrs.
    gs_upd-lifnr  = gs_bsk-lifnr.
    gs_upd-budat  = gs_bsk-budat.
    gs_upd-gjahr  = gs_bsk-gjahr.
    gs_upd-belnr  = gs_bsk-belnr.
    gs_upd-hsl    = gs_bsk-hsl.
    gs_upd-tsl    = gs_bsk-tsl.
    COLLECT gs_upd INTO gt_upd.
    CLEAR: gs_upd, gs_bsk.
  ENDLOOP.

  SORT gt_bsik BY bukrs lifnr gjahr belnr.
  DELETE ADJACENT DUPLICATES FROM gt_bsik COMPARING bukrs lifnr gjahr belnr.

  LOOP AT gt_bsik INTO gs_bsk.
    READ TABLE gt_upd INTO gs_upd WITH KEY bukrs = gs_bsk-bukrs lifnr = gs_bsk-lifnr budat = gs_bsk-budat gjahr = gs_bsk-gjahr belnr = gs_bsk-belnr.
    IF sy-subrc EQ 0.
      IF gs_bsk-hsl <> gs_upd-hsl.
        gs_bsk-hsl = gs_upd-hsl.
        gs_bsk-tsl = gs_upd-tsl.
        MODIFY gt_bsik FROM gs_bsk.
      ENDIF.
      CLEAR: gs_bsk, gs_upd.
    ENDIF.
  ENDLOOP.
* ***********************************************************************************************BOC by Rajan/Lalit Upreti.
  IF gt_bsik IS NOT INITIAL.
    SELECT DISTINCT lifnr name1 konzs kunnr ort01 stcd4 FROM lfa1 INTO TABLE gt_lfa1
         FOR ALL ENTRIES IN gt_bsik WHERE lifnr EQ gt_bsik-lifnr.


*    select ktext from cepct into table gt_cepct1 for all entries in gt_bsik
*         where spras = 'E'.

    SELECT zterm vtext FROM tvzbt INTO TABLE gt_tvzbt1
      FOR ALL ENTRIES IN gt_bsik
      WHERE zterm = gt_bsik-zterm
      AND spras = 'E'.

    SELECT bukrs belnr gjahr buzei augbl wrbtr zuonr lifnr rebzg umskz netdt koart FROM bseg INTO TABLE gt_bseg1
  FOR ALL ENTRIES IN gt_bsik
  WHERE bukrs = gt_bsik-bukrs
  AND   belnr = gt_bsik-belnr
  AND   gjahr = gt_bsik-gjahr
  AND   augbl = gt_bsik-belnr
  AND   lifnr = gt_bsik-lifnr.
*    gt_bseg2 = gt_bseg1.
*    DELETE gt_bseg2 WHERE koart NE 'K'.
    DELETE gt_bsik WHERE bschl = '40' OR bschl = '50'.
  ENDIF.
************

  REFRESH gt_knb1.
  IF p_ven = 'X'.
    CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
      EXPORTING
        text = 'Fetching opened items for Customer...'.

    " Selecting the opened items of customer data
    IF gt_bsik IS NOT INITIAL.
      SELECT  * FROM lfa1 INTO TABLE @DATA(tp_lfa1) FOR ALL ENTRIES IN @gt_bsik WHERE lifnr =  @gt_bsik-lifnr.
      IF sy-subrc = 0.
        SELECT * FROM knb1 INTO TABLE gt_knb1 FOR ALL ENTRIES IN tp_lfa1 WHERE bukrs IN s_bukrs AND kunnr = tp_lfa1-kunnr.
      ENDIF.
    ENDIF.
    IF tp_lfa1 IS NOT INITIAL.
      SELECT   a~bukrs a~kunnr a~budat a~gjahr a~belnr a~buzei a~sgtxt a~bldat a~xblnr a~vbeln a~blart a~augdt a~vbel2 a~posn2 a~zfbdt a~zterm a~zbd1t
               a~zbd2t a~zbd2t a~rebzg a~rebzt a~augbl a~umskz a~gkont a~hkont
               b~bschl b~drcrk b~hsl b~tsl b~rwcur c~bpkind INTO TABLE gt_bsid
               FROM bsid AS a  INNER JOIN faglflexa AS b
               ON a~belnr = b~belnr  AND a~buzei = b~buzei AND a~gjahr = b~ryear AND a~bukrs = b~rbukrs
               INNER JOIN  but000 AS c
               ON a~kunnr = c~partner
              FOR ALL ENTRIES IN tp_lfa1
               WHERE bukrs IN s_bukrs AND a~budat <= p_budat
               AND a~kunnr = tp_lfa1-kunnr AND b~rldnr EQ p_rldnr AND a~hkont IN s_hkont AND a~umskz IN s_umskz.

      CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
        EXPORTING
          text = 'Fetching cleared items for Customer... '.

      "Selecting the cleared items of customer data
      "" if p_budat < sy-datum.

      SELECT   a~bukrs a~kunnr a~budat a~gjahr a~belnr a~buzei a~sgtxt a~bldat a~xblnr a~vbeln a~blart a~augdt a~vbel2 a~posn2 a~zfbdt a~zterm a~zbd1t
               a~zbd2t a~zbd2t a~rebzg a~rebzt a~augbl a~umskz a~gkont a~hkont
               b~bschl b~drcrk b~hsl b~tsl b~rwcur c~bpkind APPENDING  TABLE gt_bsid
               FROM bsad AS a  INNER JOIN faglflexa AS b
               ON a~belnr = b~belnr AND a~buzei = b~buzei AND a~gjahr = b~ryear AND a~bukrs = b~rbukrs
                     INNER JOIN  but000 AS c
             ON a~kunnr = c~partner
               FOR ALL ENTRIES IN tp_lfa1
               WHERE bukrs IN s_bukrs AND a~augdt GT p_budat AND a~budat LE p_budat
               AND a~kunnr = tp_lfa1-kunnr AND b~rldnr EQ p_rldnr AND a~hkont IN s_hkont AND a~umskz IN s_umskz.
      ""endif.
    ENDIF.


    IF gt_bsid IS INITIAL.
**      message text-m01 type 'I'.
**      leave list-processing .
    ELSE.
      CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
        EXPORTING
          text = 'Fetching details... '.
      IF gt_bsid IS NOT INITIAL.
        SELECT DISTINCT kunnr name1 konzs
          FROM kna1 INTO TABLE gt_kna1
          FOR ALL ENTRIES IN gt_bsid
          WHERE kunnr EQ gt_bsid-kunnr.

        SELECT vbeln vgbel aubel
          FROM vbrp INTO TABLE gt_vbrp
          FOR ALL ENTRIES IN gt_bsid
          WHERE vbeln EQ gt_bsid-vbeln.
        IF sy-subrc = 0.
          SELECT vbeln depexnum cpudt
            FROM j_1irg23d INTO TABLE gt_rg23d
            FOR ALL ENTRIES IN gt_vbrp
            WHERE vbeln = gt_vbrp-vgbel.

          SELECT vbeln bstkd bstdk
            FROM vbkd INTO TABLE gt_vbkd
            FOR ALL ENTRIES IN gt_vbrp
            WHERE vbeln = gt_vbrp-aubel.
        ENDIF.

        SELECT vbeln fkdat fkart_rl fkdat_rl spart
          FROM vbrk INTO TABLE gt_vbrk
          FOR ALL ENTRIES IN gt_bsid
          WHERE vbeln EQ gt_bsid-vbeln.
        IF sy-subrc = 0.
          SELECT vbeln vbeln_vf
            FROM vbrl INTO TABLE gt_vbrl
            FOR ALL ENTRIES IN gt_vbrk
            WHERE vbeln_vf = gt_vbrk-vbeln.
          IF sy-subrc = 0.
            SELECT vbeln fkdat fkart_rl fkdat_rl spart
              FROM vbrk INTO TABLE it_vbrk
              FOR ALL ENTRIES IN gt_vbrl
              WHERE vbeln EQ gt_vbrl-vbeln.
          ENDIF.
        ENDIF.

        SELECT spart vtext
          FROM tspat INTO TABLE gt_tspat
          FOR ALL ENTRIES IN gt_vbrk
          WHERE spart = gt_vbrk-spart
          AND   spras = sy-langu.

*        select ktext
*          from cepct into table gt_cepct
*          for all entries in gt_bsid
*          where spras = 'E'.

        SELECT zterm vtext

          FROM tvzbt INTO TABLE gt_tvzbt
          FOR ALL ENTRIES IN gt_bsid
          WHERE zterm = gt_bsid-zterm
          AND spras = 'E'.

        SELECT rdoc2 exnum exdat
          FROM j_1iexcdtl INTO TABLE gt_excise
          FOR ALL ENTRIES IN gt_bsid
          WHERE rdoc2 = gt_bsid-vbeln
          AND   rdoc2 NE ' '.

        SELECT bukrs belnr gjahr buzei augbl
               wrbtr zuonr kunnr rebzg umskz netdt koart
          FROM bseg INTO TABLE gt_bseg
          FOR ALL ENTRIES IN gt_bsid
          WHERE bukrs = gt_bsid-bukrs
          AND   belnr = gt_bsid-belnr
          AND   gjahr = gt_bsid-gjahr
          AND   augbl = gt_bsid-belnr
          AND   kunnr = gt_bsid-kunnr.

*        gt_bseg2 = gt_bseg.
*        DELETE gt_bseg2 WHERE koart NE 'K'.
        DELETE gt_bsid WHERE bschl = '40' OR bschl = '50'.
      ENDIF.
    ENDIF.

  ENDIF.

  IF gt_bsid IS NOT INITIAL.
    SELECT bukrs belnr gjahr buzei augbl
           wrbtr zuonr kunnr rebzg umskz netdt koart
      FROM bseg INTO TABLE gt_bseg2
      FOR ALL ENTRIES IN gt_bsid
      WHERE bukrs = gt_bsid-bukrs
      AND   augbl = gt_bsid-belnr
      AND   gjahr = gt_bsid-gjahr
      AND koart = 'K'.
    IF gt_bseg2 IS NOT INITIAL.
      DELETE gt_bseg2 WHERE umskz = space.
    ENDIF.
  ENDIF.
  IF gt_bsik IS NOT INITIAL.
    SELECT bukrs belnr gjahr buzei augbl
           wrbtr zuonr kunnr rebzg umskz netdt koart
      FROM bseg APPENDING TABLE gt_bseg2
      FOR ALL ENTRIES IN gt_bsik
      WHERE bukrs = gt_bsik-bukrs
      AND   augbl = gt_bsik-belnr
      AND   gjahr = gt_bsik-gjahr
      AND koart = 'K'.
    IF gt_bseg2 IS NOT INITIAL.
      DELETE gt_bseg2 WHERE umskz = space.
    ENDIF.
  ENDIF.
ENDFORM. " GET_DATA
*&---------------------------------------------------------------------*
*&      Form  FILL_DATA
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
FORM fill_data .
  DATA: lv_tab_indx     TYPE i,
        lv_percentage   TYPE num,
        lv_stat_tx(100) TYPE c,
        lv_tabix        TYPE sy-tabix.

  DATA: lv_tab_indx1     TYPE i,
        lv_percentage1   TYPE num,
        lv_stat_tx1(100) TYPE c,
        lv_tabix1        TYPE sy-tabix.

  DATA : belnr TYPE  bkpf-belnr,
         bukrs TYPE  bkpf-bukrs,
         buzei TYPE  bseg-buzei,
         gjahr TYPE  bkpf-gjahr,
         gkont TYPE  bseg-hkont.

  DATA: lt_bsid TYPE TABLE OF ty_bsid,
        ls_bsid TYPE ty_bsid.

  DATA: lt_bsik TYPE TABLE OF ty_bsik,
        ls_bsik TYPE ty_bsik.
  DATA:lv_day TYPE i.


  CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
    EXPORTING
      text = 'Manipulating data for Vendor... '.

  LOOP AT gt_bsik INTO gs_bsik.
    READ TABLE lt_bsik INTO ls_bsik WITH KEY lifnr = gs_bsik-lifnr
                                             belnr = gs_bsik-augbl.
    IF sy-subrc = 0.
      DELETE gt_bsik.
    ENDIF.
    CLEAR: gs_bsik, ls_bsik.
  ENDLOOP.


  REFRESH lt_bsik.
  lt_bsik = gt_bsik.
  SORT gt_bsik BY lifnr belnr buzei augbl.
  SORT gt_bsik BY lifnr bldat belnr.
  DESCRIBE TABLE gt_bsik LINES lv_tab_indx1.

  LOOP AT gt_bsik INTO gs_bsik.
    lv_tabix1 = lv_tabix1 + 1.
    CLEAR lv_stat_tx1.
    lv_percentage1 = ( lv_tabix1 / lv_tab_indx1 ) * 100.
    lv_stat_tx1(3) = lv_percentage1.

    CONCATENATE lv_stat_tx1 '%' 'Prepairing for display for Vendor...'
           INTO lv_stat_tx1 SEPARATED BY space.

    CALL FUNCTION 'SAPGUI_PROGRESS_INDICATOR'
      EXPORTING
        percentage = lv_percentage1
        text       = lv_stat_tx1.

    gs_output-lifnr  = gs_bsik-lifnr.
    gs_output-bukrs  = gs_bsik-bukrs.
    READ TABLE gt_lfb1 INTO gs_lfb1 WITH KEY lifnr = gs_output-lifnr.
    IF sy-subrc = 0.
      gs_output-akont = gs_lfb1-akont.
      gs_output-xverr = gs_lfb1-xverr.
      gs_output-mindk = gs_lfb1-mindk.
    ENDIF.

    gs_output-bpkind  = gs_bsik-bpkind.
    SELECT SINGLE businesspartnertypedesc INTO gs_output-bu_text40 FROM bupa_type_text WHERE language EQ 'E' AND businesspartnertype EQ gs_bsik-bpkind.

    gs_output-sgtxt   = gs_bsik-sgtxt.
    gs_output-belnr   = gs_bsik-belnr.
    gs_output-gjahr   = gs_bsik-gjahr.
    gs_output-bldat   = gs_bsik-bldat.
    gs_output-umskz   = gs_bsik-umskz.
    gs_output-xblnr   = gs_bsik-xblnr.
    gs_output-wrbtr   = gs_bsik-tsl.
    gs_output-doccurr = gs_bsik-rwcur.
    gs_output-zfbdt   = gs_bsik-zfbdt.
    gs_output-zbd1t   = gs_bsik-zbd1t.
    gs_output-zterm   = gs_bsik-zterm.
    gs_output-blart   = gs_bsik-blart.
    gs_output-budat   = gs_bsik-budat.




    SELECT SINGLE * INTO @DATA(wa_bkpf5) FROM bkpf WHERE
                    bukrs EQ @gs_bsik-bukrs AND
                    belnr EQ @gs_bsik-belnr AND
                    gjahr EQ @gs_bsik-gjahr.

    IF sy-subrc EQ 0 AND ( gs_bsik-blart EQ 'RE' OR gs_bsik-blart EQ 'ZE' ) .
      CLEAR lv_gjahr.
      lv_gjahr = substring( off = strlen( wa_bkpf5-awkey ) - 4 len = 4 val = wa_bkpf5-awkey ).
      SELECT SINGLE * INTO @DATA(wa_rseg5) FROM rseg WHERE
                      belnr EQ @wa_bkpf5-awkey(10) AND
                      gjahr = @lv_gjahr.
*                      gjahr eq @wa_bkpf5-awkey+10(4).



      IF sy-subrc EQ 0.
        gs_output-matnr = wa_rseg5-matnr.
        SELECT SINGLE maktx INTO gs_output-maktx FROM makt WHERE matnr EQ gs_output-matnr.
      ENDIF.
    ELSE.
      gs_output-matnr = ''.
      gs_output-maktx = ''.
    ENDIF.

    CLEAR :belnr ,bukrs,buzei,gjahr,gkont.

    belnr   = gs_bsik-belnr.
    bukrs   = gs_bsik-bukrs.
    buzei   = gs_bsik-buzei.
    gjahr   = gs_bsik-gjahr.

    CALL FUNCTION 'GET_GKONT'
      EXPORTING
        belnr           = belnr
        bukrs           = bukrs
        buzei           = buzei
        gjahr           = gjahr
        gknkz           = '3'
      IMPORTING
        gkont           = gkont
*       KOART           =
*       GHKON           =
      EXCEPTIONS
        belnr_not_found = 1
        buzei_not_found = 2
        gknkz_not_found = 3
        OTHERS          = 4.
    IF sy-subrc <> 0.
* Implement suitable error handling here
    ENDIF.

    gs_output-gkont = gkont.

    IF gs_output-gkont IS NOT INITIAL.
      SELECT SINGLE * FROM skat INTO @DATA(wa_skat1) WHERE spras = 'E' AND ktopl = 'CDBG' AND saknr = @gs_output-gkont .
      IF sy-subrc = 0.
        gs_output-txt20 = wa_skat1-txt20.
      ENDIF.
    ENDIF.
    gs_output-hkont = gs_bsik-hkont.
