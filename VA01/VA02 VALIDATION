*
*
*SELECT  VBELN
*        POSNR
*        KWMENG
*     FROM VBAP INTO TABLE T_QVBAP
*     WHERE VBELN = VBAK-VBELN.
*
*SELECT VBELN
*       EDATU
*  FROM VBEP INTO TABLE T_QVBEP
*  WHERE VBELN = VBAK-VBELN.
*
*LOOP AT T_QVBAP INTO W_QVBAP.
*W_VBAP_VBEP-VBELN = W_QVBAP-VBELN.
*W_VBAP_VBEP-POSNR = W_QVBAP-POSNR.
*W_VBAP_VBEP-KWMENG = W_QVBAP-KWMENG.
*CLEAR W_QVBEP.
*READ TABLE T_QVBEP INTO W_QVBEP WITH KEY VBELN = W_QVBAP-VBELN.
*IF SY-SUBRC = 0.
