  DATA: BEGIN OF VTX_VBAP OCCURS 0.
          INCLUDE STRUCTURE VBAPVB.
  DATA: END OF VTX_VBAP.

  DATA: BEGIN OF VTX_VBEP OCCURS 0.
          INCLUDE STRUCTURE VBEPVB.
  DATA: END OF VTX_VBEP.

  DATA: BEGIN OF VTY_VBAP OCCURS 0.
          INCLUDE STRUCTURE VBAPVB.
