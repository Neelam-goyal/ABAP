          INCLUDE STRUCTURE VBEPVB.
  DATA: END OF VTY_VBEP.

  TYPES:
        BEGIN OF VT_FINAL,
        VBELN TYPE VBELN_VA,
        POSNR TYPE POSNR_VA,
        OLD_QTY TYPE MENGE_D,
        NEW_QTY TYPE MENGE_D,
        OLD_DAT TYPE EDATU,
        NEW_DAT TYPE EDATU,
