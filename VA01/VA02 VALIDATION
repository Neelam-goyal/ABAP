ENHANCEMENT 1  ZKOSTL.    "active version
if sy-tcode = 'VA01'.
if vbak-auart = 'YGSO' or vbak-auart = 'YGCR' or vbak-auart = 'YGDR'.
data lv_kostl  TYPE ZSD_SALE_GRP_TBL.
DATA LV_KOSTL1 TYPE BSEG-KOSTL.
data gs_vbap like  LINE OF xvbap[].

READ TABLE xvbap INTO gs_vbap INDEX 1.
clear: lv_kostl,LV_KOSTL1.
SELECT SINGLE cost_center FROM ZSD_SALE_GRP_TBL INTO lv_kostl  WHERE SALES_GROUP = vbak-vkgrp and PLANT = gs_vbap-werks.
SELECT SINGLE COST_CENTER FROM ZSD_SALE_GRP_TBL INTO LV_KOSTL1 WHERE SALES_GROUP = VBAK-VKGRP AND PLANT = GS_VBAP-WERKS.

  CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
    EXPORTING
      INPUT        = LV_KOSTL1
   IMPORTING
     OUTPUT        = LV_KOSTL1.

if lv_kostl1 is  INITIAl.
  MESSAGE 'Cost center does not exist in master data' TYPE 'E'.
else.
  vbak-kostl = lv_kostl1.
endif.
endif.
endif.
"""""""""""""for order type and inspection typ evalidation of material 09.02.21""""
if sy-tcode = 'VA01'  or sy-tcode = 'VA02'.
  TABLES:qmat.
  DATA:msg TYPE string.
  DATA: wA_qmat TYPE qmat.
  if VBAK-AUART = 'YGRE'.
    delete xvbap[]  WHERE kwmeng is INITIAL.
    loop AT  xvbap INTO gs_vbap.
      SELECT SINGLE * FROM qmat INTO wa_qmat
                                        WHERE art = '05'
                                        and   matnr = gs_vbap-matnr
                                        and   werks = GS_VBAP-WERKS.
        if wa_qmat is INITIAL.
          CONCATENATE 'Inspection type NOT maintained for' gs_vbap-matnr 'and' gs_vbap-werks INTO msg SEPARATED BY space.
          MESSAGE msg TYPE 'E'.
*          MESSAGE 'Inspection type NOT maintained for Material and Plant' TYPE 'E'.
*          screen-required = '1'.
        endif.
     CLEAR:wa_qmat,gs_vbap.
    ENDLOOP.
  endif.
ENDIF.
