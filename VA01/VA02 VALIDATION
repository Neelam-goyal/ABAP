      VW_FINAL-MATNR = VWX_VBAP-MATNR.                                                   "MODIFY
      VW_FINAL-VBELN = VWX_VBAP-VBELN.
      VW_FINAL-POSNR = VWX_VBAP-POSNR.
      VW_FINAL-KUNNR = VBAK-KUNNR.
      VW_FINAL-WERKS = VWX_VBAP-WERKS.
      APPEND VW_FINAL TO VT_FINAL.
      CLEAR VW_FINAL.
    ENDIF.

  ENDLOOP.

  IF VT_FINAL IS NOT INITIAL.
    PERFORM MAIL_SEND_QTY_CHANGE IN PROGRAM ZSD_QTY_CHG USING VT_FINAL.
  ENDIF.
ENDIF.
