        MATNR  TYPE MATNR,
        WERKS TYPE WERKS_D,
        END OF VT_FINAL.

  DATA: VT_FINAL TYPE STANDARD TABLE OF VT_FINAL.
  DATA: VWX_VBAP TYPE VBAPVB,
        VWX_VBEP TYPE VBEPVB,
        VWY_VBAP TYPE VBAPVB,
        VWY_VBEP TYPE VBEPVB,
        VW_FINAL TYPE VT_FINAL.

  REFRESH : VTX_VBAP,
            VTX_VBEP ,
            VTY_VBAP ,
            VTY_VBEP ,
            VT_FINAL.

  CLEAR:VWX_VBAP,
        VWX_VBEP ,
        VWY_VBAP ,
        VWY_VBEP,
        VW_FINAL .

  VTX_VBAP[] = XVBAP[].
  VTX_VBEP[] = XVBEP[].
  VTY_VBAP[] = YVBAP[].
  VTY_VBEP[] = YVBEP[].

  DELETE  VTX_VBEP  WHERE ETENR = '2'.
  DELETE  VTY_VBEP  WHERE ETENR = '2'.

  LOOP AT VTX_VBAP INTO VWX_VBAP.

    CLEAR VWY_VBAP.
    READ TABLE VTY_VBAP INTO VWY_VBAP WITH KEY VBELN = VWX_VBAP-VBELN POSNR = VWX_VBAP-POSNR.

*  IF SY-SUBRC = 0.                                 "***Modify
*    VW_FINAL-MATNR = VWY_VBAP-MATNR.
    IF SY-SUBRC = 0 AND VWX_VBAP-KWMENG NE VWY_VBAP-KWMENG.
      VW_FINAL-OLD_QTY = VWY_VBAP-KWMENG.
      VW_FINAL-NEW_QTY = VWX_VBAP-KWMENG.
    ENDIF.
*  ENDIF.                                           "***Modify

    CLEAR VWX_VBEP .
    READ TABLE VTX_VBEP INTO VWX_VBEP WITH KEY VBELN = VWX_VBAP-VBELN POSNR = VWX_VBAP-POSNR.
    IF SY-SUBRC = 0.
      CLEAR VWY_VBEP .
      READ TABLE VTY_VBEP INTO VWY_VBEP WITH KEY VBELN = VWX_VBEP-VBELN POSNR = VWX_VBEP-POSNR.
      IF SY-SUBRC = 0.
        IF VWX_VBEP-EDATU NE VWY_VBEP-EDATU.
