ENHANCEMENT 2  ZSD_INCOTERMS.    "active version
*
    FORM cnfd_date USING CALCDT L_ZDAYS.
 DATA  :         l_factid TYPE FABKL,
     l TYPE i,
     t_dats TYPE TABLE OF RKE_DAT,
      zdays TYPE T5A4A-DLYDY.

SELECT SINGLE FABKL FROM T001W INTO l_factid WHERE  werks = vbap-werks.
      refresh:t_dats.
  CALL FUNCTION 'RKE_SELECT_FACTDAYS_FOR_PERIOD'
    EXPORTING
      I_DATAB                     = vbak-AUDAT
      I_DATBI                     = CALCDt
      I_FACTID                    = l_FACTID
    TABLES
      ETH_DATS                    = t_DATS
   EXCEPTIONS
     DATE_CONVERSION_ERROR       = 1
            .
  DESCRIBE TABLE t_dats LINES l.
  IF l <> l_zdays.
ZDAYS = l_zdays - l.
  CALL FUNCTION 'RP_CALC_DATE_IN_INTERVAL'
    EXPORTING
      DATE            = calcdt
      DAYS            = zDAYS
      MONTHS          = '0'
      SIGNUM          = '+'
      YEARS           = '0'
   IMPORTING
     CALC_DATE       = CALCDt
            .
  PERFORM cnfd_date USING calcdt l_zdays.
else.
  vbkd-BSTDK_E = CALCDt.
  ENDIF.
    endform.
ENDENHANCEMENT.
