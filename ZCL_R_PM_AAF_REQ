  METHOD assetitem.

    DATA : it_items_create TYPE TABLE FOR CREATE zr_pm_aaf_req\_item.

    " ============================================================
    " STEP 1: Read current entity state (header + items)
    " ============================================================
    READ ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
      ENTITY aaf_req
      ALL FIELDS WITH CORRESPONDING #( keys )
      RESULT DATA(lit_header)
      ENTITY aaf_req_i
      ALL FIELDS WITH CORRESPONDING #( keys )
      RESULT DATA(lit_item).

    " ============================================================
    " STEP 2: Loop over all header records in keys
    " ============================================================
    LOOP AT lit_header INTO DATA(lwa_header).

      " ----------------------------------------------------------
      " GUARD 1: Skip if MaterialDoc is blank - nothing to process
      " ----------------------------------------------------------
**    CHECK lwa_header-materialdoc IS NOT INITIAL.

      CHECK lwa_header-ponumber      IS NOT INITIAL AND
            lwa_header-poitem        IS NOT INITIAL AND
            lwa_header-materialdoc   IS NOT INITIAL AND
            lwa_header-materialdocitem IS NOT INITIAL.
      " ----------------------------------------------------------
      " GUARD 2: Skip if reqnr already set
      " This is the KEY anti-recursion guard.
      " When our own MODIFY fires the determination again,
      " reqnr will already be populated so we exit immediately.
      " ----------------------------------------------------------
*    CHECK lwa_header-reqnr IS INITIAL.
      IF lwa_header-reqnrt IS NOT INITIAL.

        DATA(lv_expected_reqnrt_fragment) =
           |{ lwa_header-ponumber }-{ lwa_header-poitem }-{ lwa_header-materialdoc }-{ lwa_header-materialdocitem }|.
        IF lwa_header-reqnrt EQ lv_expected_reqnrt_fragment.
          " Scenario B: Same materialdoc already processed.
          " This is the recursive re-trigger. Exit immediately.
          CONTINUE.
        ELSE.
          " Scenario C: materialdoc has changed.
          " Delete existing draft items so we can recreate them.
          SELECT *
            FROM zpm_aaf_req_id
            WHERE cuuid = @lwa_header-cuuid
            INTO TABLE @DATA(lit_df_tbi).


          IF lit_df_tbi IS NOT INITIAL.
            MODIFY ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
              ENTITY aaf_req_i
              DELETE FROM VALUE #(
                FOR ls_dtb IN lit_df_tbi (
                  %is_draft   = '01'
                  %key-cuuid  = ls_dtb-cuuid
                  %key-cuuidi = ls_dtb-cuuidi
                )
              )
              REPORTED DATA(lit_del_rep)
              FAILED   DATA(lit_del_fai).
*            CLEAR LWA_HEADER. "ONCE PREVIOUS RECORD IS DELETED REMOVE PREVIOUS DATA
          ENDIF.

        ENDIF.
      ENDIF.


      " ============================================================
      " STEP 3: Validate Purchase Order exists in system
      " ============================================================
      SELECT SINGLE purchasingdocument
        FROM i_purchasingdocument
        WHERE purchasingdocument = @lwa_header-ponumber
        INTO @DATA(lv_po).

      IF lv_po IS INITIAL.
        reported-aaf_req = VALUE #( BASE reported-aaf_req (
          %tky = lwa_header-%tky
          %msg = new_message_with_text(
                   severity = if_abap_behv_message=>severity-error
                   text     = 'Purchase Order is Not In System' )
        ) ).
        CONTINUE.  "skip this header, continue with next
      ENDIF.


      " ============================================================
      " STEP 5: Fetch PO and MIGO data from purchase document view
      " ============================================================
      SELECT *
        FROM zi_pm_purchasedocument
        WHERE ponumber    = @lwa_header-ponumber
          AND poitem      = @lwa_header-poitem
          AND materialdoc = @lwa_header-materialdoc
          AND materialdocitem = @lwa_header-materialdocitem
        INTO TABLE @DATA(lit_tb_data).

      DATA(lwa_tb_data) = VALUE #( lit_tb_data[ 1 ] OPTIONAL ).

      IF lwa_tb_data IS INITIAL.
        reported-aaf_req = VALUE #( BASE reported-aaf_req (
          %tky = lwa_header-%tky
          %msg = new_message_with_text(
                   severity = if_abap_behv_message=>severity-error
                   text     = 'No PO / MIGO data found for this document' )
        ) ).
        CONTINUE.
      ENDIF.



      " ============================================================
      " STEP 6: Fetch total amount from AAF RAP view
      " ============================================================
      SELECT SINGLE *
        FROM zi_aaf_req_rap
        WHERE purchaseorder = @lwa_tb_data-ponumber
        AND   purchaseorderitem   = @lwa_tb_data-poitem
         AND materialdocument = @lwa_tb_data-materialdoc

        INTO @DATA(ls_totalamount).

      DATA(lv_qty_int) = CONV i( lwa_tb_data-qty ).


      IF lv_qty_int <= 0.
        reported-aaf_req = VALUE #( BASE reported-aaf_req (
          %tky = lwa_header-%tky
          %msg = new_message_with_text(
                   severity = if_abap_behv_message=>severity-error
                   text     = 'Quantity is zero - cannot create asset items' )
        ) ).
        CONTINUE.
      ENDIF.    " ============================================================
      " STEP 10: Build item create table - one entry per quantity
      " e.g. qty = 10 → 10 line items auto-created
      " ============================================================
      DATA(lv_sr) = 0.

  " Get next request number once before loop
      SELECT SINGLE MAX( reqnr )
        FROM zpm_aaf_req
        INTO @DATA(lv_reqnr).

**   if lv_reqnr is not iniTIAL.
**      SELECT *
**        FROM  ZCPM_AAF_APPR1
**        WHERE requestNo    = @lv_reqnr
**        INTO TABLE @DATA(lit_tb_seq).
**
***      DATA(lwa_tb_seq) = VALUE #( lit_tb_seq[ 1 ] OPTIONAL ).
** endif.
**
** DATA(lv_seqno) = 0.
**
**IF lit_tb_seq IS NOT INITIAL.
**  lv_seqno = lit_tb_seq[ 1 ]-seqNo.
**ENDIF.

      lv_reqnr += 1 .

      DO lv_qty_int TIMES.
        lv_sr = lv_sr + 1.

        it_items_create = VALUE #( BASE it_items_create (
          %tky      = lwa_header-%tky
          %is_draft = lwa_header-%is_draft
          %pky      = lwa_header-%pky
          %target   = VALUE #( (
            %key = VALUE #(
              cuuid  = lwa_header-cuuid
              cuuidi = cl_system_uuid=>create_uuid_x16_static( )
            )
            %cid          = |item_{ lwa_header-cuuid }_{ lv_sr }|

            " ── Sequence and identification ──────────────
            srno          = lv_sr
            ponumber      = lwa_header-ponumber
            asscat        = lwa_header-asscat
            assetcategory = lwa_header-assetcategory
            Reqnr = lv_reqnr

            " ── Financial ────────────────────────────────
            costcenter    = lwa_tb_data-kostl
            totalamount   = ls_totalamount-totalamount
            amountcuky    = ls_totalamount-curry

            " ── Manufacturer information ──────────────────
            manufacturename    = lwa_tb_data-manufacturername  " LFA1-NAME1 via MFRNR
            manufacturepartno  = lwa_tb_data-mfrpn             " EKPO-MFRPN
            manufacturetel     = lwa_tb_data-manufacturertel   " ADRC via MFRNR
            manufactureaddress = lwa_tb_data-vendorstreet      " ADRC via MFRNR

            " ── Vendor information ────────────────────────
            vendorid           = lwa_tb_data-supplier          " EKKO-LIFNR
            localvendor        = lwa_tb_data-vendorname        " LFA1-NAME1 via LIFNR
            vendortel          = lwa_tb_data-vendortel         " ADRC via LIFNR
            localvendoraddress = lwa_tb_data-vendorcity        " ADRC via LIFNR
            acquisitionvalue =  ls_totalamount-totalamount
             cukyfield         = lwa_tb_data-curry
             acquisitiondate = sy-datum
             migono = lwa_tb_data-materialdoc
             migodocitem = lwa_tb_data-materialdocitem

             "-------Approver Detail
*             seqno = lv_seqno


            %is_draft     = lwa_header-%is_draft

            " ── Control flags ────────────────────────────
            %control = VALUE #(
              cuuid              = if_abap_behv=>mk-on
              cuuidi             = if_abap_behv=>mk-on
              srno               = if_abap_behv=>mk-on
              ponumber           = if_abap_behv=>mk-on
              costcenter         = if_abap_behv=>mk-on
              functionallocation = if_abap_behv=>mk-on
              assectno           = if_abap_behv=>mk-on
              reqnr              = if_abap_behv=>mk-on
              totalamount        = if_abap_behv=>mk-on
              amountcuky         = if_abap_behv=>mk-on
              manufacturename    = if_abap_behv=>mk-on
              manufacturepartno  = if_abap_behv=>mk-on
              manufacturetel     = if_abap_behv=>mk-on
              manufactureaddress = if_abap_behv=>mk-on
              vendorid           = if_abap_behv=>mk-on
              localvendor        = if_abap_behv=>mk-on
              vendortel          = if_abap_behv=>mk-on
              localvendoraddress = if_abap_behv=>mk-on
              acquisitiondate    = if_abap_behv=>mk-on
              migono             = if_abap_behv=>mk-on
              migodocitem        = if_abap_behv=>mk-on
*              seqno              = if_abap_behv=>mk-on
            )
          ) )
        ) ).

      ENDDO.


      DATA(lv_new_reqnr) = |{ lwa_header-ponumber }-{ lwa_header-poitem }-{ lwa_header-materialdoc }-{ lwa_header-materialdocitem }|.



      " ============================================================
      " STEP 8: Update header fields
      " IMPORTANT: materialdoc is intentionally NOT in UPDATE FIELDS
      " Including materialdoc would re-trigger this determination
      " causing the infinite recursion / short dump
      " ============================================================
      MODIFY ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
        ENTITY aaf_req
        UPDATE FIELDS (
          plant
          materialdocitem
          qty
          poqty
          reqnrt
          reqnr
          acquisitionvalue

          cukyfield
          assetdescription
          acquisitiondate
          manufacturename
          vendorid
*          seqno
        )
        WITH VALUE #( (
            %tky             = lwa_header-%tky
            plant            = lwa_tb_data-plant
            " materialdoc   --> intentionally excluded, causes infinite loop
            materialdocitem  = lwa_tb_data-materialdocitem
            qty              = lwa_tb_data-qty
            poqty            = lwa_tb_data-poqty
            reqnrt            = lv_new_reqnr
            reqnr = lv_reqnr
            acquisitionvalue = lwa_tb_data-amountcurry

            cukyfield         = lwa_tb_data-curry
            assetdescription = lwa_tb_data-txz01
            acquisitiondate  = sy-datum
            manufacturename  = lwa_tb_data-mfrnr
            vendorid         = lwa_tb_data-supplier

        ) )
        FAILED FINAL(lv_fail)
        REPORTED FINAL(lv_rep).

      " ============================================================
      " STEP 9: Convert qty (decimal/packed) to integer for DO loop
      " DO...TIMES requires plain integer - decimal fails silently
      " ============================================================

    ENDLOOP.  "end LOOP AT lit_header

    " ============================================================
    " STEP 11: Execute all item creates in one single EML call
    " Done outside the loop for performance - batch all at once
    " ============================================================
    IF it_items_create IS NOT INITIAL.

      MODIFY ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
        ENTITY aaf_req
        CREATE BY \_item
        FROM it_items_create
        MAPPED DATA(lit_mapped)
        FAILED DATA(lit_failed)
        REPORTED DATA(lit_reported2).

      " Report failure details if any items failed to create
      IF lit_failed IS NOT INITIAL.
        reported-aaf_req = VALUE #( BASE reported-aaf_req (
          %tky = lit_header[ 1 ]-%tky
          %msg = new_message_with_text(
                   severity = if_abap_behv_message=>severity-error
                   text     = 'Some asset items failed to create - check data' )
        ) ).
      ENDIF.

    ENDIF.

  ENDMETHOD.
