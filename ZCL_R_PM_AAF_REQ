  METHOD update_revnr.

" Step 1: Read existing data from Buffer
*READ ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
*  ENTITY aaf_req_i
*  FIELDS ( reqnr revnr )
*  WITH CORRESPONDING #( keys )
*  RESULT DATA(lt_result)
*  FAILED DATA(lt_failed)
*  reported data(lt_reported).

  READ ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
  ENTITY aaf_req
  FIELDS ( reqnr revnr )
  WITH CORRESPONDING #( keys )
  RESULT DATA(lt_result)
  FAILED DATA(lt_failed)
  reported data(lt_reported).

  if lt_result is not inITIAL.
  data(lv_reqnr) = lt_result[ 1 ]-reqnr.
  endif.

SELECT MAX( REVNR ) FROM ZPM_AAF_REQ_I INTO @data(LV_REVNR)  WHERE REQNR =  @lv_reqnr.


  " Step 2: Get all unique Request Numbers
  DATA(lt_req_keys) = lt_result.
  SORT lt_req_keys BY reqnr.
  DELETE ADJACENT DUPLICATES FROM lt_req_keys COMPARING reqnr.

  " Step 3: ONE Select for all records (No MAX, No GROUP BY)
  SELECT reqnr, revnr
    FROM zpm_aaf_req_i
    FOR ALL ENTRIES IN @lt_req_keys
    WHERE reqnr = @lt_req_keys-reqnr
    INTO TABLE @DATA(lt_db_revs).

  " Step 4: Find the MAX in ABAP memory (Super fast)
  " Sort descending so the highest revision is at the top for each request
  SORT lt_db_revs BY reqnr ASCENDING revnr DESCENDING.
  " Keep only the top record for each request
  DELETE ADJACENT DUPLICATES FROM lt_db_revs COMPARING reqnr.

  " Step 5: Prepare the update
  DATA lt_update TYPE TABLE FOR UPDATE zr_pm_aaf_req\\aaf_req_i.

  LOOP AT lt_result ASSIGNING FIELD-SYMBOL(<fs_res>).

    " Now lt_db_revs ONLY contains the max revision for each request
    READ TABLE lt_db_revs WITH KEY reqnr = <fs_res>-reqnr
                          ASSIGNING FIELD-SYMBOL(<fs_max>).

    DATA(lv_next_rev) = COND int1( WHEN sy-subrc = 0
                                THEN <fs_max>-revnr + 1
                                ELSE 1 ).

    APPEND VALUE #(
        %tky   = <fs_res>-%tky
        %cid_ref = <fs_res>-Cuuid
        revnr  = lv_next_rev
        %control-revnr = if_abap_behv=>mk-on
    ) TO lt_update.

  ENDLOOP.

  " Step 6: Final Modifydet
*  MODIFY ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
*    ENTITY aaf_req_i
*    UPDATE FIELDS ( revnr ) WITH lt_update.

endmETHOD.
