METHOD get_instance_features.

  READ ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
    ENTITY aaf_req_i
    FIELDS ( Cuuid CuuidI WorkflowTriggered )
    WITH CORRESPONDING #( keys )
    RESULT DATA(lt_items).

  IF lt_items IS INITIAL.
    RETURN.
  ENDIF.

  " 👉 Explicit type definition (FIX)
  TYPES: BEGIN OF ty_key,
           cuuid   TYPE zpm_aaf_req_i-cuuid,
           cuuid_i TYPE zpm_aaf_req_i-cuuid_i,
         END OF ty_key.

  DATA: lt_keys_db TYPE STANDARD TABLE OF ty_key WITH EMPTY KEY.

  lt_keys_db = VALUE #(
    FOR ls IN lt_items
    WHERE ( cuuid IS NOT INITIAL AND cuuidi IS NOT INITIAL )
    ( cuuid = ls-cuuid
      cuuid_i = ls-cuuidi )
  ).

  IF lt_keys_db IS INITIAL.
    RETURN.
  ENDIF.

  SELECT cuuid, cuuid_i, workflow_triggered
    FROM zpm_aaf_req_i
    INTO TABLE @DATA(lt_db)
    FOR ALL ENTRIES IN @lt_keys_db
    WHERE cuuid   = @lt_keys_db-cuuid
      AND cuuid_i = @lt_keys_db-cuuid_i.

  LOOP AT lt_items INTO DATA(ls_item).

    DATA(lv_flag) = VALUE #( lt_db[
      cuuid   = ls_item-cuuid
      cuuid_i = ls_item-cuuidi ]-workflow_triggered OPTIONAL ).

    APPEND VALUE #(
      %tky = ls_item-%tky

      %field-costcenter =
        COND #(
          WHEN lv_flag = abap_true OR ls_item-workflowtriggered = abap_true
          THEN if_abap_behv=>fc-f-read_only
          ELSE if_abap_behv=>fc-f-unrestricted )

    ) TO result.

  ENDLOOP.

ENDMETHOD.


  METHOD set_workflow_flag.
*    BREAK-POINT.

    READ ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
      ENTITY aaf_req_i
      FIELDS ( isselected )
      WITH CORRESPONDING #( keys )
      RESULT DATA(lt_items).

    DATA lt_update TYPE TABLE FOR UPDATE zr_pm_aaf_req\\aaf_req_i.

    LOOP AT lt_items INTO DATA(ls_item).

      IF ls_item-isselected = abap_true.

        APPEND VALUE #(
          %tky = ls_item-%tky
          workflowtriggered = abap_true
          %control-workflowtriggered = if_abap_behv=>mk-on
        ) TO lt_update.

      ENDIF.

    ENDLOOP.

    IF lt_update IS NOT INITIAL.
      MODIFY ENTITIES OF zr_pm_aaf_req IN LOCAL MODE
        ENTITY aaf_req_i
        UPDATE FIELDS ( workflowtriggered )
        WITH lt_update.
    ENDIF.

  ENDMETHOD.


ENDCLASS.

