FORM track .
  CLEAR: lo_http, lo_rest, lo_entity, lo_response, t_header,
      v_in, v_url, v_uri, rv_out, v_xin.
  READ TABLE it_gatentryitm INTO DATA(lv_gate) WITH KEY vbeln_inv = ls-vbeln.
  READ TABLE it_gate_out INTO DATA(lv_gate1) WITH KEY gateentryno = lv_gate-gateentryno.
  IF lv_gate1 IS NOT INITIAL.
    IF gv_lr_no IS INITIAL.
      gv_lr_no = lv_gate1-lrno.
      IF gv_lr_no IS INITIAL.
        gv_lr_no = '-'.
      ENDIF.
    ENDIF.
    IF gv_vehicle_no IS INITIAL.
      gv_vehicle_no = lv_gate1-truckno.
      IF gv_vehicle_no IS INITIAL.
        gv_vehicle_no = '-'.
      ENDIF.
    ENDIF.
  ENDIF.

  CONCATENATE '['
    '"' gv_vehicle_no '"'
']' INTO v_in.
  mi_rlength = strlen( v_in ).
  v_url = 'https://etranssolutions.com/eTransRestApi/reports/location'.

  cl_http_client=>create_by_url( EXPORTING  url                = v_url
                                 IMPORTING  client             = lo_http
                                 EXCEPTIONS argument_not_found = 1
                                            plugin_not_active  = 2
                                            internal_error     = 3
                                            OTHERS             = 4 ).
  IF sy-subrc = 0.
    lo_http->request->set_method( 'GET' ).
    lo_http->request->set_content_type( 'application/json' ) ##NO_TEXT.
    CALL METHOD lo_http->request->set_header_field
      EXPORTING
        name  = 'username'
        value = 'JYOTISPL'.
    CALL METHOD lo_http->request->set_header_field
      EXPORTING
        name  = 'password'
        value = 'oG8lv0rKJrA7e2g'.


    CALL METHOD lo_http->request->set_cdata
      EXPORTING
        data   = v_in
        offset = 0
        length = mi_rlength.
    lo_http->propertytype_logon_popup = if_http_client=>co_disabled.
    lo_http->send( EXCEPTIONS http_communication_failure = 1
                              http_invalid_state         = 2 ).
    IF sy-subrc = 0.
      lo_http->receive( EXCEPTIONS http_communication_failure = 1
                                   http_invalid_state         = 2
                                   http_processing_failed     = 3 ).
      IF sy-subrc = 0.
        lo_http->response->get_header_fields( CHANGING fields = t_header ).
        READ TABLE t_header ASSIGNING <header> WITH KEY name = '~status_code'.
        IF sy-subrc = 0.
          CASE <header>-value.
            WHEN '200'.
              v_out = lo_http->response->get_cdata( ).
            WHEN OTHERS.
          ENDCASE.
        ENDIF.
      ENDIF.
    ENDIF.
  ENDIF.
  IF v_out IS NOT INITIAL.
    SPLIT v_out AT '"liveTrackLink":' INTO DATA(b1) DATA(b2).
    SPLIT b2 AT '"}],' INTO DATA(b3) DATA(b4).
    SPLIT b3 AT '"' INTO DATA(b5) DATA(b6).
    url = b6.
  ENDIF.

ENDFORM.
