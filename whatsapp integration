      IF lw_audit-usr IS INITIAL.
        SELECT SINGLE * INTO lw_auth FROM zdg_sign_auth WHERE uname = lw_audit-usr AND werks = wa_vb-werks AND fkart = wa_vb-fkart.
        CONCATENATE '"' lw_auth-name1 '",' INTO jsignname.
      ELSE.
        CONCATENATE '"' lw_audit-name1 '",' INTO jsignname. "skgupta
      ENDIF.
    ENDIF.
  ELSE.
    SELECT * INTO TABLE  lt_audit FROM zdsign_audit WHERE vbeln = gv_tcno.
    READ TABLE lt_audit INTO lw_audit WITH KEY vbeln = gv_tcno.
    IF sy-subrc = 0.
      CONCATENATE '"' lw_audit-name1 '",' INTO jsignname.   "skgupta
    ENDIF.
  ENDIF.

  CLEAR : lv_hr,lv_time,lv_date.

  IF lv_type = 'I'.
    READ TABLE lt_audit INTO lw_audit WITH KEY vbeln = p_vbeln1.
  ELSE.
    READ TABLE lt_audit INTO lw_audit WITH KEY vbeln = gv_tcno.
  ENDIF.

  IF sy-subrc = 0.
    lv_hr = lw_audit-ztime(2).
    IF lv_hr GE '12'.
      lv_ampm = 'PM'.
      IF lv_hr > '12'.
        lv_hr = lw_audit-ztime(2) - 12.
      ENDIF.
    ELSE.
      lv_ampm = 'AM'.
    ENDIF.
    CONCATENATE '"' lw_audit-zdate+6(2) '/' lw_audit-zdate+4(2) '/' lw_audit-zdate(4) INTO lv_date.
    CONCATENATE lv_hr ':' lw_audit-ztime+2(2) ':' lw_audit-ztime+4(2) INTO lv_time.
    CONCATENATE lv_date lv_time lv_ampm '",' INTO jsigndate SEPARATED BY space.
  ENDIF.

  jissignby = 'true,'.
  CONCATENATE '"' page_str '",' INTO jpageno.
  CONCATENATE  '"' pdf '"' INTO jdoc.
  CONDENSE : jname ,jsignpage ,jxloc, jyloc, jsignreason,jsignname,jissignby,jpageno,jdoc.
  CONCATENATE  '{' '"Name":' jname '"SignPage":' jsignpage '"SignMode":' jsignmode '"DSCTokenName":' jdscname '"DSCPassword":' jdscpass '"XLoc":' jxloc '"YLoc":' jyloc '"signReason":' jsignreason
  '"signerName":' jsignname '"signdatetime":' jsigndate '"IsSignedBy":' jissignby '"PageNo":' jpageno '"Document":' jdoc '}' INTO  mij_gw_string.
  CONDENSE  mij_gw_string.
*  BREAK mawai_abap.
  lr_link->request->set_cdata( EXPORTING data = mij_gw_string ).

  CALL METHOD lr_link->send
    EXPORTING
      timeout                    = 15   " 15 Seconds
    EXCEPTIONS
      http_communication_failure = 1
      http_invalid_state         = 2.

  CALL METHOD lr_link->receive
    EXCEPTIONS
      http_communication_failure = 1
      http_invalid_state         = 2
      http_processing_failed     = 3.


  lr_link->response->get_status( IMPORTING code = gw_http_return_code1 ).
  lr_link->response->get_status( IMPORTING reason = gw_http_error_descr1 ).
  gw_http_error_descr_long1 = lr_link->response->get_raw_message( ).


  CALL METHOD lr_link->refresh_request(
    EXCEPTIONS
      http_action_failed = 1
      OTHERS             = 2 ).
  CLEAR gw_xml_result_str1.
  gw_xml_result_str1 = lr_link->response->get_cdata( ).

  lr_link->close( ).
  SPLIT gw_xml_result_str1 AT '"' INTO TABLE itab.
  DESCRIBE TABLE itab LINES lv_tab.
  READ TABLE itab INTO wtab INDEX lv_tab - 1.
  IF wtab = 'Digital Sign successfully'.
    SPLIT gw_xml_result_str1 AT '"' INTO lv1 lv2 lv3 lv4 lv5 lv6 lv7.


    CALL FUNCTION 'SCMS_BASE64_DECODE_STR'
      EXPORTING
        input  = lv4
      IMPORTING
        output = opdf
      EXCEPTIONS
        failed = 1
        OTHERS = 2.
    IF sy-subrc <> 0.
*         Implement suitable error handling here
    ENDIF.

    IF lv_type = 'I'.
      CLEAR:i_invbin[].
      FREE:i_invbin[].
      CLEAR merged_document.

*      REFRESH merged_document[].
      CALL FUNCTION 'SCMS_XSTRING_TO_BINARY'
        EXPORTING
          buffer     = opdf
        TABLES
          binary_tab = i_invbin[].
      IF sy-subrc IS INITIAL.
        pdff->add_document( opdf ).
      ENDIF.
      pdff->merge_documents(
        IMPORTING
          merged_document = merged_document
      ).
      CLEAR opdf.

    ELSEIF lv_type = 'Q'.
      CLEAR:i_qcbin[].
      FREE:i_qcbin[].
      CALL FUNCTION 'SCMS_XSTRING_TO_BINARY'
        EXPORTING
          buffer     = opdf
        TABLES
          binary_tab = i_qcbin[].
      IF sy-subrc IS INITIAL.
        pdff->add_document( opdf ).
      ENDIF.
      pdff->merge_documents(
        IMPORTING
          merged_document = merged_document
      ).
      CLEAR opdf.
    ENDIF.
  ELSE.
    MESSAGE 'Error has occured' TYPE 'E'.
  ENDIF.
ENDFORM.
